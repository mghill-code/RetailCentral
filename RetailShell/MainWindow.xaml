<Window x:Class="RetailShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RetailShell"
        Height="600"
        Width="1000"
        Background="White">

    <Window.Resources>

        <!-- Modern kiosk button style with dark gray hover -->
        <Style TargetType="Button" x:Key="KioskButtonStyle">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Shadow"
                                    CornerRadius="16"
                                    Background="#000000"
                                    Opacity="0.08"
                                    Margin="0,4,0,0"/>

                            <Border x:Name="Surface"
                                    CornerRadius="16"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#4B5563"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#374151"/>
                                <Setter TargetName="Shadow" Property="Opacity" Value="0.18"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#374151"/>
                                <Setter TargetName="Shadow" Property="Margin" Value="0,1,0,0"/>
                                <Setter TargetName="Shadow" Property="Opacity" Value="0.05"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Shadow" Property="Opacity" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Center -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->

        <!-- Logo top-left -->
        <Image Source="logo.png"
               Grid.Row="0"
               Width="240"
               Height="120"
               Margin="20"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Stretch="Uniform"/>

        <!-- System Info top-right -->
        <Border Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                Padding="12"
                Background="#AAFFFFFF"
                CornerRadius="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="System Information"
                           FontWeight="Bold"
                           TextDecorations="Underline"
                           Grid.Row="0"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Computer Name:" Grid.Row="1" FontWeight="Bold"/>
                <TextBlock Name="TxtComputerName" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="System Boot Time:" Grid.Row="2" FontWeight="Bold"/>
                <TextBlock Name="TxtBootTime" Grid.Row="2" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="Computer Model:" Grid.Row="3" FontWeight="Bold"/>
                <TextBlock Name="TxtComputerModel" Grid.Row="3" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="Store Number:" Grid.Row="4" FontWeight="Bold"/>
                <TextBlock Name="TxtStoreNumber" Grid.Row="4" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="Register Number:" Grid.Row="5" FontWeight="Bold"/>
                <TextBlock Name="TxtRegisterNumber" Grid.Row="5" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="IP Address:" Grid.Row="6" FontWeight="Bold"/>
                <TextBlock Name="TxtIPAddress" Grid.Row="6" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="MAC Address:" Grid.Row="7" FontWeight="Bold"/>
                <TextBlock Name="TxtMacAddress" Grid.Row="7" Grid.Column="1" Margin="8,0,0,0"/>

                <TextBlock Text="PinPAD IP Address:" Grid.Row="8" FontWeight="Bold"/>
                <TextBlock Name="TxtPinPadIP" Grid.Row="8" Grid.Column="1" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ================= CENTER BRAND PANEL ================= -->

        <Border Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="28"
                Padding="30"
                Margin="20"
                BorderBrush="#40FFFFFF"
                BorderThickness="1">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#80FFFFFF" Offset="0"/>
                    <GradientStop Color="#55FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <!-- Glass highlight -->
                <Ellipse Width="520"
                         Height="180"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,-90,0,0"
                         Opacity="0.18">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Brand image loaded in code -->
                <Image x:Name="BrandImage"
                       Width="520"
                       Height="180"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </Border>

        <!-- ================= FOOTER ================= -->

        <Border Grid.Row="2"
                Background="#66DDDDDD"
                CornerRadius="16"
                Padding="18"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom">

            <Grid>
                <StackPanel Name="MainButtonsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Name="BtnLaunchPOS"
                            Content="Launch POS"
                            Style="{StaticResource KioskButtonStyle}"/>

                    <Button Name="BtnExitPOS"
                            Content="Exit POS"
                            Style="{StaticResource KioskButtonStyle}"/>

                    <Button Name="BtnUtilities"
                            Content="Utilities"
                            Style="{StaticResource KioskButtonStyle}"/>
                </StackPanel>

                <StackPanel Name="UtilitiesPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">

                    <Button Name="BtnScreenCalibrate"
                            Style="{StaticResource KioskButtonStyle}"
                            Visibility="Collapsed"/>

                    <Button Name="BtnPinPad"
                            Style="{StaticResource KioskButtonStyle}"
                            Visibility="Collapsed"/>

                    <Button Name="BtnScannerProgram"
                            Style="{StaticResource KioskButtonStyle}"
                            Visibility="Collapsed"/>

                    <Button Name="BtnReboot"
                            Style="{StaticResource KioskButtonStyle}"
                            Visibility="Collapsed"/>

                    <Button Name="BtnShutdown"
                            Style="{StaticResource KioskButtonStyle}"
                            Visibility="Collapsed"/>

                    <Button Name="BtnBack"
                            Content="Back"
                            Style="{StaticResource KioskButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>