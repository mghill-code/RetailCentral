{
  "EnableAnimations": true,
  "EnableLogging": true,
  "LogFolder": "Logs",
  "LogRetentionDays": 30,

  "ScreenCalibrateAllowedModels": [
    "NCR 70XRT",
    "NCR 72XRT"
  ],

  "POS": {
    "ExecutablePath": "C:\\BNCPOS\\bncpos.exe",
    "Arguments": "",
    "WorkingDirectory": "C:\\BNCPOS",
    "AutoLaunch": true,
    "LaunchDelaySeconds": 2
  },

  "UserActivity": {
    "Enabled": true,
    "SnapshotPath": "Shared\\UserActivity.json",
    "WriteIntervalSeconds": 30,
    "ActiveThresholdSeconds": 60,
    "POSProcessName": "bncpos"
  },

  "Utilities": [
    {
      "Name": "Screen Calibrate",
      "Exe": "C:\\Windows\\notepad.exe"
    },
    {
      "Name": "Configure PinPad",
      "Exe": "C:\\Windows\\regedit.exe"
    },
    {
      "Name": "Scanner Program",
      "Exe": ""
    },
    {
      "Name": "Reboot",
      "Exe": "shutdown /r /t 30"
    },
    {
      "Name": "Shutdown",
      "Exe": "shutdown /s /t 30"
    }
  ]
}
