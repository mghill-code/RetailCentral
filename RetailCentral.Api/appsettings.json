  "ProcessStatusSchedule": {
    "Enabled": true,
    "RunEveryMinutes": 5,
    "ActiveDeviceDays": 7,
    "SuccessFreshMinutes": 5,
    "Priority": 40,
    "MaxAttempts": 2
  },
  "DataRetention": {
    "HeartbeatDays": 30,
    "CommandResultDays": 90,
    "CompletedCommandDays": 90,
    "RunDailyAtHourUtc": 3,
    "DeleteDevicesAfterDays": 0
