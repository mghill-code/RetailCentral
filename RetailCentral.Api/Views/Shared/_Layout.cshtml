<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@(ViewData["Title"] as string ?? "RetailCommand - Device Control Center")</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body>
    @using Microsoft.AspNetCore.Authorization
    @using Microsoft.AspNetCore.Html
    @inject IAuthorizationService AuthorizationService

    @functions {
        public IHtmlContent SvgIcon(string key)
        {
            var svg = key switch
            {
                "control-center" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z'/><path d='M7 20h10'/><path d='M9 16v4'/><path d='M15 16v4'/></svg>",
                "inventory" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 7l8 -4l8 4l-8 4z'/><path d='M4 12l8 4l8 -4'/><path d='M4 17l8 4l8 -4'/></svg>",
                "devices" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z'/><path d='M7 21h10'/><path d='M9 17v4'/><path d='M15 17v4'/></svg>",
                "groups" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M8 7a3 3 0 1 0 0 .01'/><path d='M16 7a3 3 0 1 0 0 .01'/><path d='M5 19a3 3 0 0 1 6 0'/><path d='M13 19a3 3 0 0 1 6 0'/></svg>",
                "versions" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M7 12l3 3l7 -7'/><path d='M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2z'/></svg>",
                "about" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 9h.01'/><path d='M11 12h1v4h1'/><path d='M12 3a9 9 0 1 0 0 18a9 9 0 0 0 0 -18z'/></svg>",
                "commands" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M8 9l-3 3l3 3'/><path d='M13 15h6'/><path d='M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2z'/></svg>",
                "helpdesk" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 5h16v11h-6l-4 4v-4h-6z'/><path d='M9.5 9a2.5 2.5 0 1 1 3.8 2.1c-.75 .45 -1.3 .89 -1.3 1.9'/><path d='M12 15h.01'/></svg>",
                "issue" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 19l7 -7l-3 -3l-7 7l-1 4z'/><path d='M16 5l3 3'/></svg>",
                "packages" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3l8 4.5v9l-8 4.5l-8 -4.5v-9z'/><path d='M12 12l8 -4.5'/><path d='M12 12v9'/><path d='M12 12l-8 -4.5'/></svg>",
                "new-deployment" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 5v14'/><path d='M5 12h14'/><path d='M5 5h14v14h-14z'/></svg>",
                "deployment-center" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 13h5v7h-5z'/><path d='M10 9h5v11h-5z'/><path d='M16 4h4v16h-4z'/></svg>",
                "audit" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M9 11l3 3l8 -8'/><path d='M20 12v7a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h9'/></svg>",
                "reports" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M14 3v4a1 1 0 0 0 1 1h4'/><path d='M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z'/><path d='M9 9h1'/><path d='M9 13h6'/><path d='M9 17h6'/></svg>",
                "refresh" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4'/><path d='M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4'/></svg>",
                "theme-light" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3v2'/><path d='M12 19v2'/><path d='M3 12h2'/><path d='M19 12h2'/><path d='M5.6 5.6l1.4 1.4'/><path d='M17 17l1.4 1.4'/><path d='M5.6 18.4l1.4 -1.4'/><path d='M17 7l1.4 -1.4'/><path d='M12 8a4 4 0 1 0 0 8a4 4 0 0 0 0 -8z'/></svg>",
                "theme-dark" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z'/></svg>",
                _ => "<svg viewBox='0 0 24 24' aria-hidden='true'><circle cx='12' cy='12' r='9'/></svg>"
            };

            return new HtmlString(svg);
        }
    }

    @{
        var currentPath = Context?.Request?.Path.Value ?? string.Empty;

        string NavClass(string pathPrefix)
        {
            if (string.IsNullOrWhiteSpace(currentPath))
                return string.Empty;

            return currentPath.StartsWith(pathPrefix, StringComparison.OrdinalIgnoreCase)
            ? "nav-active"
            : string.Empty;
        }

        var canView = (await AuthorizationService.AuthorizeAsync(User, "DashboardViewer")).Succeeded;
        var canHelpdesk = (await AuthorizationService.AuthorizeAsync(User, "DashboardHelpdesk")).Succeeded;
        var canEngineer = (await AuthorizationService.AuthorizeAsync(User, "DashboardEngineer")).Succeeded;
        var canAdmin = (await AuthorizationService.AuthorizeAsync(User, "DashboardAdmin")).Succeeded;
    }

    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <img src="/images/logo.png" class="sidebar-logo" alt="RetailCommand" />
                <div class="sidebar-brand-copy">
                    <div class="sidebar-kicker">Device Control Center</div>
                    <div class="sidebar-title">RetailCommand</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (canView)
                {
                    <div class="sidebar-section-label">Fleet Overview</div>
                    <a href="/" class="@(currentPath == "/" ? "nav-active" : string.Empty)">
                        <span class="nav-icon">@SvgIcon("control-center")</span>
                        <span class="nav-label">Control Center</span>
                    </a>
                    <a href="/Dashboard/RegisterInventory" class="@NavClass("/Dashboard/RegisterInventory")">
                        <span class="nav-icon">@SvgIcon("inventory")</span>
                        <span class="nav-label">Register Inventory</span>
                    </a>
                    <a href="/Dashboard/Devices" class="@NavClass("/Dashboard/Devices")">
                        <span class="nav-icon">@SvgIcon("devices")</span>
                        <span class="nav-label">Managed Devices</span>
                    </a>
                    <a href="/Dashboard/Groups" class="@NavClass("/Dashboard/Groups")">
                        <span class="nav-icon">@SvgIcon("groups")</span>
                        <span class="nav-label">Groups</span>
                    </a>
                    <a href="/Dashboard/Versions" class="@NavClass("/Dashboard/Versions")">
                        <span class="nav-icon">@SvgIcon("versions")</span>
                        <span class="nav-label">Versions</span>
                    </a>
                    <a href="/Dashboard/About" class="@NavClass("/Dashboard/About")">
                        <span class="nav-icon">@SvgIcon("about")</span>
                        <span class="nav-label">About</span>
                    </a>

                    <div class="sidebar-section-label">Commands &amp; Support</div>
                    <a href="/Dashboard/Commands" class="@NavClass("/Dashboard/Commands")">
                        <span class="nav-icon">@SvgIcon("commands")</span>
                        <span class="nav-label">Command Center</span>
                    </a>
                }

                @if (canHelpdesk)
                {
                    <a href="/Dashboard/HelpdeskCommands" class="@NavClass("/Dashboard/HelpdeskCommands")">
                        <span class="nav-icon">@SvgIcon("helpdesk")</span>
                        <span class="nav-label">Helpdesk Commands</span>
                    </a>
                }

                @if (canEngineer)
                {
                    <a href="/Dashboard/IssueCommand" class="@NavClass("/Dashboard/IssueCommand")">
                        <span class="nav-icon">@SvgIcon("issue")</span>
                        <span class="nav-label">Issue Command</span>
                    </a>

                    <div class="sidebar-section-label">Deployments</div>
                    <a href="/Dashboard/Packages" class="@NavClass("/Dashboard/Packages")">
                        <span class="nav-icon">@SvgIcon("packages")</span>
                        <span class="nav-label">Packages</span>
                    </a>
                    <a href="/Dashboard/CreateDeployment" class="@NavClass("/Dashboard/CreateDeployment")">
                        <span class="nav-icon">@SvgIcon("new-deployment")</span>
                        <span class="nav-label">New Deployment</span>
                    </a>
                    <a href="/Dashboard/Deployments" class="@NavClass("/Dashboard/Deployments")">
                        <span class="nav-icon">@SvgIcon("deployment-center")</span>
                        <span class="nav-label">Deployment Center</span>
                    </a>
                }

                @if (canAdmin)
                {
                    <div class="sidebar-section-label">Administration</div>
                    <a href="/Dashboard/Audit" class="@NavClass("/Dashboard/Audit")">
                        <span class="nav-icon">@SvgIcon("audit")</span>
                        <span class="nav-label">Audit Logs</span>
                    </a>
                    <a href="/Dashboard/LogsDashboard" class="@NavClass("/Dashboard/LogsDashboard")">
                        <span class="nav-icon">@SvgIcon("reports")</span>
                        <span class="nav-label">Reports &amp; Logs</span>
                    </a>
                }
            </nav>
        </aside>

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <div class="content-shell" id="contentShell">
            <header class="utility-topbar">
                <div class="utility-topbar-inner">
                    <div class="utility-left">
                        <button id="sidebarToggle" class="sidebar-toggle" type="button" aria-label="Toggle navigation" title="Toggle navigation">
                            <svg viewBox="0 0 24 24" class="sidebar-toggle-icon" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="16" rx="3" ry="3" fill="none" stroke="currentColor" stroke-width="1.8"></rect>
                                <line x1="9" y1="4" x2="9" y2="20" stroke="currentColor" stroke-width="1.8"></line>
                            </svg>
                        </button>

                        <div class="utility-title-block">
                            <div class="page-kicker">RetailCommand</div>
                            <div class="page-title-inline">@(ViewData["Title"] as string ?? "Device Control Center")</div>
                        </div>
                    </div>

                    <div class="utility-right">
                        <div class="auto-refresh toolbar-group utility-refresh-group">
                            <label for="autoRefreshSelect">Auto Refresh</label>
                            <select id="autoRefreshSelect" class="compact-select">
                                <option value="0">Off</option>
                                <option value="30">30 sec</option>
                                <option value="60">60 sec</option>
                                <option value="120">2 min</option>
                                <option value="300">5 min</option>
                            </select>
                            <button type="button" class="btn btn-secondary has-icon" id="refreshNowBtn">
                                <span class="action-icon">@SvgIcon("refresh")</span>
                                <span class="btn-label">Refresh Now</span>
                            </button>
                        </div>

                        <div class="toolbar-group toolbar-meta" id="refreshStamp"></div>

                        <button id="darkToggle" type="button" class="sidebar-icon has-icon" title="Toggle dark mode">
                            <span class="toolbar-icon" id="darkToggleIcon">@SvgIcon("theme-dark")</span>
                            <span id="darkToggleLabel">Dark</span>
                        </button>
                    </div>
                </div>
            </header>

            <main class="page-shell">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        const toggle = document.getElementById("darkToggle");
        const autoRefreshSelect = document.getElementById("autoRefreshSelect");
        const refreshNowBtn = document.getElementById("refreshNowBtn");
        const sidebarToggle = document.getElementById("sidebarToggle");
        const sidebarBackdrop = document.getElementById("sidebarBackdrop");

        let refreshIntervalHandle = null;
        let formDirty = false;

        function getRefreshManager() {
            return window.dashboardRefreshManager || null;
        }

        function isMobileLayout() {
            return window.matchMedia("(max-width: 840px)").matches;
        }

        function applyTheme(theme) {
            document.documentElement.setAttribute("data-theme", theme);
            localStorage.setItem("dashboard-theme", theme);

            if (toggle) {
                const toggleLabel = document.getElementById("darkToggleLabel");
                const toggleIcon = document.getElementById("darkToggleIcon");

                if (toggleLabel) {
                    toggleLabel.textContent = theme === "dark" ? "Light" : "Dark";
                }

                if (toggleIcon) {
                    toggleIcon.innerHTML = theme === "dark"
                        ? `<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3v2'/><path d='M12 19v2'/><path d='M3 12h2'/><path d='M19 12h2'/><path d='M5.6 5.6l1.4 1.4'/><path d='M17 17l1.4 1.4'/><path d='M5.6 18.4l1.4 -1.4'/><path d='M17 7l1.4 -1.4'/><path d='M12 8a4 4 0 1 0 0 8a4 4 0 0 0 0 -8z'/></svg>`
                        : `<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z'/></svg>`;
                }

                toggle.setAttribute("title", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");
            }
        }

        function updateRefreshStamp() {
            const el = document.getElementById("refreshStamp");
            if (el) {
                el.textContent = "Last refreshed: " + new Date().toLocaleTimeString();
            }
        }

        function clearAutoRefresh() {
            if (refreshIntervalHandle) {
                clearInterval(refreshIntervalHandle);
                refreshIntervalHandle = null;
            }
        }

        function pageDisablesRefresh() {
            const skipAuto = document.body.getAttribute("data-no-autorefresh");
            if (skipAuto === "true") return true;
            if (formDirty) return true;

            const mgr = getRefreshManager();
            if (mgr && typeof mgr.isBusy === "function" && mgr.isBusy()) {
                return true;
            }

            return false;
        }

        const refreshScrollKey = "dashboard-refresh-scroll";

        function saveScrollPositionForReload() {
            try {
                sessionStorage.setItem(refreshScrollKey, JSON.stringify({
                    url: window.location.pathname + window.location.search + window.location.hash,
                    x: window.scrollX || 0,
                    y: window.scrollY || 0
                }));
            } catch { }
        }

        function restoreScrollPositionAfterReload() {
            try {
                const raw = sessionStorage.getItem(refreshScrollKey);
                if (!raw) return;

                const saved = JSON.parse(raw);
                const currentUrl = window.location.pathname + window.location.search + window.location.hash;

                if (saved && saved.url === currentUrl) {
                    window.scrollTo(saved.x || 0, saved.y || 0);
                }

                sessionStorage.removeItem(refreshScrollKey);
            } catch { }
        }

        async function safeRefresh() {
            const mgr = getRefreshManager();

            if (mgr && typeof mgr.refresh === "function") {
                await mgr.refresh();
                updateRefreshStamp();
                return;
            }

            saveScrollPositionForReload();
            formDirty = false;
            const nextUrl = window.location.pathname + window.location.search + window.location.hash;
            window.location.assign(nextUrl);
        }

        function updateRefreshUiState() {
            const disabled = pageDisablesRefresh();

            if (autoRefreshSelect) {
                autoRefreshSelect.disabled = disabled;
                autoRefreshSelect.title = disabled
                    ? "Auto refresh is disabled while editing a form."
                    : "";
            }

            if (refreshNowBtn) {
                refreshNowBtn.disabled = disabled;
                refreshNowBtn.title = disabled
                    ? "Refresh is disabled while editing a form."
                    : "";
            }
        }

        function setAutoRefresh(seconds) {
            clearAutoRefresh();

            const parsed = parseInt(seconds, 10) || 0;
            localStorage.setItem("dashboard-auto-refresh-seconds", parsed.toString());

            if (autoRefreshSelect) {
                autoRefreshSelect.value = parsed.toString();
            }

            if (parsed > 0) {
                refreshIntervalHandle = setInterval(async () => {
                    updateRefreshUiState();

                    if (!pageDisablesRefresh()) {
                        await safeRefresh();
                    }
                }, parsed * 1000);
            }
        }

        function wireFormTracking() {
            const forms = document.querySelectorAll("form");
            if (!forms.length) {
                updateRefreshUiState();
                return;
            }

            const fields = document.querySelectorAll("form input, form textarea, form select");
            fields.forEach(field => {
                field.addEventListener("input", () => {
                    formDirty = true;
                    updateRefreshUiState();
                });

                field.addEventListener("change", () => {
                    formDirty = true;
                    updateRefreshUiState();
                });
            });

            forms.forEach(form => {
                form.addEventListener("submit", () => {
                    formDirty = false;
                    updateRefreshUiState();
                });
            });

            window.addEventListener("beforeunload", function (e) {
                if (!formDirty) return;
                e.preventDefault();
                e.returnValue = "";
            });

            updateRefreshUiState();
        }

        function openMobileSidebar() {
            document.body.classList.add("sidebar-open");
        }

        function closeMobileSidebar() {
            document.body.classList.remove("sidebar-open");
        }

        function applyDesktopSidebarState() {
            if (isMobileLayout()) {
                document.body.classList.remove("sidebar-collapsed");
                return;
            }

            const collapsed = localStorage.getItem("dashboard-sidebar-collapsed") === "true";
            document.body.classList.toggle("sidebar-collapsed", collapsed);
        }

        function toggleSidebar() {
            if (isMobileLayout()) {
                document.body.classList.contains("sidebar-open")
                    ? closeMobileSidebar()
                    : openMobileSidebar();
                return;
            }

            const collapsed = !document.body.classList.contains("sidebar-collapsed");
            document.body.classList.toggle("sidebar-collapsed", collapsed);
            localStorage.setItem("dashboard-sidebar-collapsed", collapsed ? "true" : "false");
        }

        sidebarToggle?.addEventListener("click", toggleSidebar);
        sidebarBackdrop?.addEventListener("click", closeMobileSidebar);

        window.addEventListener("resize", function () {
            if (!isMobileLayout()) {
                closeMobileSidebar();
            }

            applyDesktopSidebarState();
            updateRefreshUiState();
        });

        if (toggle) {
            toggle.addEventListener("click", function () {
                const current = localStorage.getItem("dashboard-theme") || "light";
                applyTheme(current === "dark" ? "light" : "dark");
            });
        }

        autoRefreshSelect?.addEventListener("change", function () {
            setAutoRefresh(this.value);
            updateRefreshUiState();
        });

        refreshNowBtn?.addEventListener("click", async function () {
            if (pageDisablesRefresh()) {
                return;
            }

            await safeRefresh();
        });

        wireFormTracking();
        applyDesktopSidebarState();

        const savedTheme = localStorage.getItem("dashboard-theme") || "light";
        applyTheme(savedTheme);

        const savedRefresh = localStorage.getItem("dashboard-auto-refresh-seconds") || "30";
        setAutoRefresh(savedRefresh);

        restoreScrollPositionAfterReload();
        updateRefreshStamp();
        updateRefreshUiState();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
