@model RetailCentral.Api.ViewModels.DevicesFilterViewModel

@{
    ViewData["Title"] = "Devices";

    string chipClass(string value)
    {
        return string.Equals(Model.Status, value, StringComparison.OrdinalIgnoreCase)
            ? "chip nav-active"
            : "chip";
    }

    var selectedGroupText = string.IsNullOrWhiteSpace(Model.GroupName)
        ? "More Filters"
        : $"Group: {Model.GroupName}";
}

<div class="page-header">
    <div class="page-heading-copy">
        <h1>Devices</h1>
        <p>Browse devices, inspect health, and take recovery actions.</p>
    </div>
    <div class="page-actions">
        <a class="btn has-icon" href="/Dashboard/HelpdeskCommands">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <path d="M4 5h16v11h-6l-4 4v-4h-6z" />
                    <path d="M9.5 9a2.5 2.5 0 1 1 3.8 2.1c-.75 .45 -1.3 .89 -1.3 1.9" />
                    <path d="M12 15h.01" />
                </svg>
            </span>
            <span class="btn-label">Helpdesk Commands</span>
        </a>

        <a class="btn btn-secondary has-icon" href="/Dashboard/IssueCommand">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <path d="M12 19l7 -7l-3 -3l-7 7l-1 4z" />
                    <path d="M16 5l3 3" />
                </svg>
            </span>
            <span class="btn-label">Issue Command</span>
        </a>

        <button type="button" id="refreshNowBtn" class="btn btn-secondary has-icon">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4" />
                    <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4" />
                </svg>
            </span>
            <span class="btn-label">Refresh</span>
        </button>
    </div>
</div>

<div class="card toolbar-card">
    <div class="chips" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <a class="@chipClass("Active")" href="/Dashboard/Devices?status=Active">All Devices (Active)</a>
        <a class="@chipClass("Online")" href="/Dashboard/Devices?status=Online">Online</a>
        <a class="@chipClass("Offline")" href="/Dashboard/Devices?status=Offline">Offline</a>
        <a class="@chipClass("Retired")" href="/Dashboard/Devices?status=Retired">Retired</a>

        <form method="get" action="/Dashboard/Devices" style="display:inline-flex; gap:8px; align-items:center;">
            <input type="hidden" name="status" value="@Model.Status" />
            <select name="groupName" onchange="this.form.submit()" class="compact-select" aria-label="Filter by group">
                <option value="">More Filters</option>
                @foreach (var g in Model.AvailableGroups)
                {
                    if (string.Equals(Model.GroupName, g, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@g" selected>@g</option>
                    }
                    else
                    {
                        <option value="@g">@g</option>
                    }
                }
            </select>

            @if (!string.IsNullOrWhiteSpace(Model.GroupName))
            {
                <a class="btn btn-secondary" href="/Dashboard/Devices?status=@Model.Status">Clear Group</a>
            }
        </form>
    </div>

    <div class="subtle" style="margin-top:10px;">
        Showing @Model.Devices.Count
        @if (string.Equals(Model.Status, "Retired", StringComparison.OrdinalIgnoreCase))
        {
            <text> retired devices</text>
        }
        else
        {
            <text> active devices</text>
        }

        @if (!string.IsNullOrWhiteSpace(Model.GroupName))
        {
            <text> in group "@Model.GroupName"</text>
        }
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table class="devices-table">
            <thead>
                <tr>
                    <th style="width:10%;">Store</th>
                    <th style="width:26%;">Hostname</th>
                    <th style="width:12%;">Status</th>
                    <th style="width:18%;">Version</th>
                    <th style="width:22%;">Last Seen</th>
                    <th style="width:12%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Devices)
                {
                    var isRetired = string.Equals(Model.Status, "Retired", StringComparison.OrdinalIgnoreCase);

                    <tr>
                        <td>@d.StoreNumber</td>
                        <td>
                            <div><a href="/Dashboard/Device/@d.DeviceId"><strong>@d.Hostname</strong></a></div>
                            <div class="subtle">DeviceId: @d.DeviceId</div>
                        </td>
                        <td>
                            @if (isRetired)
                            {
                                <span class="badge badge-offline">Retired</span>
                            }
                            else
                            {
                                <span class="badge @(d.IsOnline ? "badge-online" : "badge-offline")">
                                    @(d.IsOnline ? "Online" : "Offline")
                                </span>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(d.AgentVersion) ? "-" : d.AgentVersion)</td>
                        <td>@(d.LastSeenUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")</td>
                        <td>
                            <div class="action-row">
                                <a class="btn btn-outline" href="/Dashboard/Device/@d.DeviceId">Open</a>

                                @if (!isRetired)
                                {
                                    <form method="post"
                                          action="/Dashboard/RetireDevice"
                                          class="inline"
                                          onsubmit="return confirm('Retire device @d.Hostname? History will be kept.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deviceId" value="@d.DeviceId" />
                                        <button class="btn btn-danger" @(d.IsOnline ? "disabled" : null)>Retire</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const storageKey = "devices-scroll-y";

            function saveScrollPosition() {
                try {
                    sessionStorage.setItem(storageKey, String(window.scrollY || window.pageYOffset || 0));
                } catch { }
            }

            function restoreScrollPosition() {
                try {
                    const raw = sessionStorage.getItem(storageKey);
                    if (raw !== null) {
                        const y = parseInt(raw, 10);
                        if (!Number.isNaN(y)) {
                            window.scrollTo(0, y);
                        }
                    }
                } catch { }
            }

            function refreshPage() {
                saveScrollPosition();
                window.location.reload();
            }

            restoreScrollPosition();

            window.addEventListener("beforeunload", saveScrollPosition);

            const refreshBtn = document.getElementById("refreshNowBtn");
            if (refreshBtn) {
                refreshBtn.addEventListener("click", refreshPage);
            }

            window.setInterval(refreshPage, 30000);
        })();
    </script>
}