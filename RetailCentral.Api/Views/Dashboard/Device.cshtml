                    </tbody>
                </table>
            </div>

            @if (updatesRemaining.Count > 0)
            {
                <details style="margin-top:12px;">
                    <summary style="cursor:pointer; font-weight:600;">
                        Show remaining @updatesRemaining.Count update entries
                    </summary>

                    <div class="table-wrap" style="margin-top:12px;">
                        <table>
                            <thead>
                                <tr>
                                    <th>HotFix ID</th>
                                    <th>Description</th>
                                    <th>Installed On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in updatesRemaining)
                                {
                                    <tr>
                                        <td>@(item.HotFixId ?? "-")</td>
                                        <td>@(item.Description ?? "-")</td>
                                        <td>@(item.InstalledOn ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </details>
            }
        }
    </div>
</div>

