<div id="commandDetailModal" class="rc-modal" style="display:none;">
    <div class="rc-modal-backdrop"></div>
    <div class="rc-modal-dialog">
        <div class="rc-modal-header">
            <h3 style="margin:0;">Command Detail</h3>
            <button type="button" class="btn btn-secondary" id="closeCommandDetailModal">Close</button>
        </div>
        <div class="rc-modal-body" id="commandDetailModalBody">
            <div>Loading...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                async function copyShadowCommand(cmd) {
                    if (!cmd) {
                        alert('No shadow session command is available for this device.');
                        return;
                    }

                    try {
                        await navigator.clipboard.writeText(cmd);
                        alert('Shadow session command copied:

        ' + cmd);
                    } catch {
                        alert('Unable to copy shadow session command.

        ' + cmd);
                    }
                }

                async function copyText(text, successMessage) {
                    if (!text) {
                        alert('No value is available to copy for this device.');
                        return;
                    }

                    try {
                        await navigator.clipboard.writeText(text);
                        alert(successMessage || ('Copied: ' + text));
                    } catch {
                        alert('Unable to copy: ' + text);
                    }
                }

                async function openCommandDetailModal(commandId) {
                    const modal = document.getElementById('commandDetailModal');
                    const body = document.getElementById('commandDetailModalBody');

                    if (!modal || !body || !commandId) return;

                    body.innerHTML = '<div>Loading...</div>';
                    modal.style.display = 'block';

                    try {
                        const response = await fetch(`/Dashboard/CommandModal/${commandId}`);

                        if (!response.ok) {
                            body.innerHTML = '<div class="alert alert-warning">Unable to load command detail.</div>';
                            return;
                        }

                        const html = await response.text();
                        body.innerHTML = html;
                    } catch {
                        body.innerHTML = '<div class="alert alert-warning">Unable to load command detail.</div>';
                    }
                }

                function closeCommandDetailModal() {
                    const modal = document.getElementById('commandDetailModal');
                    if (modal) {
                        modal.style.display = 'none';
                    }
                }

                document.addEventListener('click', function (e) {
                    const link = e.target.closest('.command-detail-link');
                    if (!link) return;

                    e.preventDefault();

                    const commandId = link.getAttribute('data-command-id');
                    if (!commandId) return;

                    openCommandDetailModal(commandId);
                });

                function formatLocalDateTime(value) {
                    if (!value) return 'Unknown';

                    const date = new Date(value);
                    if (isNaN(date.getTime())) return 'Unknown';

                    const yyyy = date.getFullYear();
                    const mm = String(date.getMonth() + 1).padStart(2, '0');
                    const dd = String(date.getDate()).padStart(2, '0');
                    const hh = String(date.getHours()).padStart(2, '0');
                    const mi = String(date.getMinutes()).padStart(2, '0');
                    const ss = String(date.getSeconds()).padStart(2, '0');

                    return `${yyyy}-${mm}-${dd} ${hh}:${mi}:${ss}`;
                }

                function setText(id, value) {
                    const el = document.getElementById(id);
                    if (el) {
                        el.innerText = value ?? 'Unknown';
                    }
                }

                async function refreshActivity() {
                    try {
                        const response = await fetch(`/Dashboard/DeviceActivityData?id=@Model.DeviceId`, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        if (!response.ok) {
                            console.error('Activity refresh failed with status', response.status);
                            return;
                        }

                        const data = await response.json();

                        if (!data) {
                            return;
                        }

                        setText('activity-session-state', data.sessionState || 'Unknown');
                        setText('activity-console-user', data.consoleUser || 'Unknown');
                        setText('idle-time', data.idleDisplay || 'Unknown');
                        setText('user-active', data.isUserActive ? 'Yes' : 'No');
                        setText('pos-foreground', data.isPosForeground ? 'Yes' : 'No');
                        setText('idle-seconds', data.idleSeconds ?? 'Unknown');
                        setText('last-input', formatLocalDateTime(data.lastInput));
                        setText('activity-captured', formatLocalDateTime(data.capturedUtc));
                        setText('activity-updated', formatLocalDateTime(data.updatedUtc));

                        const statusEl = document.getElementById('activity-status');
                        if (statusEl) {
                            if (data.isUserActive) {
                                statusEl.innerText = 'Active';
                                statusEl.className = 'badge bg-success';
                            } else if (typeof data.idleSeconds === 'number' && data.idleSeconds >= 900) {
                                statusEl.innerText = 'Idle (15+ min)';
                                statusEl.className = 'badge bg-danger';
                            } else {
                                statusEl.innerText = 'Idle';
                                statusEl.className = 'badge bg-warning text-dark';
                            }
                        }
                    } catch (err) {
                        console.error('Activity refresh failed', err);
                    }
                }

                document.addEventListener('DOMContentLoaded', function () {
                    const closeBtn = document.getElementById('closeCommandDetailModal');
                    if (closeBtn) {
                        closeBtn.addEventListener('click', closeCommandDetailModal);
                    }

                    const modal = document.getElementById('commandDetailModal');
                    if (modal) {
                        const backdrop = modal.querySelector('.rc-modal-backdrop');
                        if (backdrop) {
                            backdrop.addEventListener('click', closeCommandDetailModal);
                        }
                    }

                    window.dashboardRefreshManager = {
                        refresh: async function () {
                            await refreshActivity();
                        },
                        isBusy: function () {
                            const modal = document.getElementById('commandDetailModal');
                            return !!(modal && modal.style.display === 'block');
                        }
                    };

                    refreshActivity();
                });
    </script>
}
