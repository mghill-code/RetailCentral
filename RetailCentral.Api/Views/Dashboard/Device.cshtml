@model RetailCentral.Api.ViewModels.DeviceDetailViewModel
@using System.Text.Json
@using Microsoft.AspNetCore.Html

@functions {
    public IHtmlContent SvgIcon(string key)
    {
        var svg = key switch
        {
            "deploy" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3l8 4.5v9l-8 4.5l-8 -4.5v-9z'/><path d='M12 12l8 -4.5'/><path d='M12 12v9'/><path d='M12 12l-8 -4.5'/></svg>",
            "helpdesk" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 5h16v11h-6l-4 4v-4h-6z'/><path d='M9.5 9a2.5 2.5 0 1 1 3.8 2.1c-.75 .45 -1.3 .89 -1.3 1.9'/><path d='M12 15h.01'/></svg>",
            "command" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M8 9l-3 3l3 3'/><path d='M13 15h6'/><path d='M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2z'/></svg>",
            "system" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 6v6l4 2'/><path d='M12 3a9 9 0 1 0 0 18a9 9 0 0 0 0 -18z'/></svg>",
            "network" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 18a2 2 0 1 0 0 .01'/><path d='M8.5 15a5 5 0 0 1 7 0'/><path d='M5 11.5a10 10 0 0 1 14 0'/><path d='M1.5 8a15 15 0 0 1 21 0'/></svg>",
            "process" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 4h6v6h-6z'/><path d='M14 4h6v6h-6z'/><path d='M4 14h6v6h-6z'/><path d='M17 14v6'/><path d='M14 17h6'/></svg>",
            "software" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M9 3h6l1 2h4v6l-2 1v3l2 1v3h-4l-1 2h-6l-1 -2h-4v-3l2 -1v-3l-2 -1v-6h4z'/><path d='M9 12h6'/><path d='M12 9v6'/></svg>",
            "restart" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4'/><path d='M12 7v5l3 3'/></svg>",
            "reboot" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 2v10'/><path d='M18.36 6.64a9 9 0 1 1 -12.72 0'/></svg>",
            "requeue" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 4v6h6'/><path d='M20 20v-6h-6'/><path d='M5.5 15a7 7 0 0 0 11.95 2'/><path d='M18.5 9a7 7 0 0 0 -11.95 -2'/></svg>",
            "retire" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 7h16'/><path d='M10 11v6'/><path d='M14 11v6'/><path d='M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12'/><path d='M9 7v-3h6v3'/></svg>",
            "shadow" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-4l-3 3l-3 -3h-4a2 2 0 0 1 -2 -2z'/><path d='M9 9h6'/><path d='M9 12h4'/></svg>",
            "download" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3v12'/><path d='M8 11l4 4l4 -4'/><path d='M4 21h16'/></svg>",
            "copy" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M8 8m0 2a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-8a2 2 0 0 1 -2 -2z'/><path d='M16 8v-2a2 2 0 0 0 -2 -2h-8a2 2 0 0 0 -2 2v8a2 2 0 0 0 2 2h2'/></svg>",
            _ => "<svg viewBox='0 0 24 24' aria-hidden='true'><circle cx='12' cy='12' r='9'/></svg>"
        };

        return new HtmlString(svg);
    }
}

@{
    ViewData["Title"] = "Device Detail";
    var recentFailed = Model.RecentCommands.Where(c => c.Status == "Failed").ToList();
    var protocolTargetEncoded = Uri.EscapeDataString(Model.RemoteAssistanceTarget ?? "");
    var protocolLaunchUrl = $"retailshadow://shadow?target={protocolTargetEncoded}";
}


<style>
    .page-actions,
    .helpdesk-quick-actions {
        gap: 10px;
    }

        .page-actions .btn,
        .helpdesk-quick-actions .btn,
        .helpdesk-quick-actions button,
        .helpdesk-quick-actions a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

    .icon-inline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        flex-shrink: 0;
    }

        .icon-inline svg {
            width: 18px;
            height: 18px;
            stroke: currentColor;
            stroke-width: 1.9;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
        }
</style>

@if (TempData["DeviceMessage"] != null)
{
    <div class="alert alert-success">@TempData["DeviceMessage"]</div>
}

<div class="page-header">
    <div>
        <h1>@Model.Hostname</h1>
        <p>Device detail, health posture, quick actions, and recent command activity.</p>
    </div>
    <div class="page-actions">
        <a class="btn" href="/Dashboard/CreateDeployment?targetType=1&targetValue=@Model.DeviceId"><span class="icon-inline">@SvgIcon("deploy")</span><span>Deploy to Device</span></a>
        <a class="btn btn-secondary" href="/Dashboard/HelpdeskCommands?deviceId=@Model.DeviceId"><span class="icon-inline">@SvgIcon("helpdesk")</span><span>Helpdesk</span></a>
        <a class="btn btn-outline" href="/Dashboard/IssueCommand?deviceId=@Model.DeviceId"><span class="icon-inline">@SvgIcon("command")</span><span>Advanced Command</span></a>
    </div>
</div>

@if (Model.Health != null)
{
    var h = Model.Health;
    var statusCss = h.Status switch
    {
        "Healthy" => "badge-online",
        "Warning" => "badge-pending",
        _ => "badge-offline"
    };

    <div class="card">
        <h3>Health Score</h3>
        <div class="health-legend">
            <div class="legend-section">
                <strong>Score Calculation</strong>
                <ul>
                    <li>@Model.HealthLegendHeartbeat</li>
                    <li>@Model.HealthLegendDisk</li>
                    <li>@Model.HealthLegendMemory</li>
                    <li>@Model.HealthLegendFailures</li>
                    <li>@Model.HealthLegendInventory</li>
                </ul>
            </div>
            <div class="legend-section">
                <strong>Status Levels</strong>
                <ul>
                    <li><span class="badge badge-online">Healthy</span> 90–100</li>
                    <li><span class="badge badge-pending">Warning</span> 70–89</li>
                    <li><span class="badge badge-offline">Critical</span> 0–69</li>
                </ul>
            </div>
            <div class="legend-section">
                <strong>Column Meanings</strong>
                <ul>
                    <li><span class="health-ok">OK</span> = passing check</li>
                    <li><span class="health-issue">Issue</span> = problem detected</li>
                    <li><span class="health-stale">Stale</span> = inventory older than 24h</li>
                </ul>
            </div>
        </div>

        <div class="device-health-summary">
            <div class="device-health-score-block">
                <div class="progress">
                    <div class="progress-bar @(h.Status == "Healthy" ? "success" : h.Status == "Warning" ? "pending" : "failed")" style="width:@h.Score%;"></div>
                </div>
                <div class="device-health-score-text">@h.Score%</div>
                <div style="margin-top:8px;"><span class="badge @statusCss">@h.Status</span></div>
            </div>
            <div class="device-health-checks">
                <div><strong>Heartbeat:</strong> <span class="@(h.HeartbeatHealthy ? "health-ok" : "health-issue")">@(h.HeartbeatHealthy ? "OK" : "Issue")</span></div>
                <div><strong>Disk:</strong> <span class="@(h.DiskHealthy ? "health-ok" : "health-issue")">@(h.DiskHealthy ? "OK" : "Issue")</span></div>
                <div><strong>Memory:</strong> <span class="@(h.MemoryHealthy ? "health-ok" : "health-issue")">@(h.MemoryHealthy ? "OK" : "Issue")</span></div>
                <div><strong>Recent Failures:</strong> <span class="@(h.FailuresHealthy ? "health-ok" : "health-issue")">@(h.FailuresHealthy ? "OK" : "Issue")</span></div>
                <div><strong>Inventory:</strong> <span class="@(h.InventoryFresh ? "health-ok" : "health-stale")">@(h.InventoryFresh ? "Fresh" : "Stale")</span></div>
                <div><strong>Last Heartbeat:</strong> @(h.LastHeartbeatUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div>
                <div><strong>Inventory Updated:</strong> @(h.InventoryUpdatedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div>
                <div><strong>Disk Free:</strong> @(h.HardDriveFreeSpace ?? "-")</div>
                <div><strong>Disk Size:</strong> @(h.HardDriveSize ?? "-")</div>
                <div><strong>Memory:</strong> @(h.Memory ?? "-")</div>
            </div>
        </div>
    </div>
}

<div class="grid-2">
    <div class="card">
        <h3>Device Summary</h3>
        <div class="kv-grid">
            <div class="kv-item"><span class="kv-label">Store</span><span class="kv-value">@Model.StoreNumber</span></div>
            <div class="kv-item"><span class="kv-label">Status</span><span class="kv-value"><span class="badge @(Model.IsOnline ? "badge-online" : "badge-offline")">@(Model.IsOnline ? "Online" : "Offline")</span></span></div>
            <div class="kv-item"><span class="kv-label">Agent Version</span><span class="kv-value">@(Model.AgentVersion ?? "-")</span></div>
            <div class="kv-item"><span class="kv-label">OS Version</span><span class="kv-value">@(Model.OsVersion ?? "-")</span></div>
            <div class="kv-item"><span class="kv-label">Machine Name</span><span class="kv-value">@(Model.MachineName ?? "-")</span></div>
            <div class="kv-item"><span class="kv-label">Machine Guid</span><span class="kv-value">@(Model.MachineGuid ?? "-")</span></div>
            <div class="kv-item"><span class="kv-label">Last Seen</span><span class="kv-value">@Model.LastSeenUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>
            <div class="kv-item"><span class="kv-label">Last IP</span><span class="kv-value">@(Model.LastIp ?? "-")</span></div>
            <div class="kv-item"><span class="kv-label">First Seen</span><span class="kv-value">@Model.FirstSeenUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>
            <div class="kv-item"><span class="kv-label">Enabled</span><span class="kv-value">@(Model.IsEnabled ? "Yes" : "Retired")</span></div>
        </div>

        @if (Model.Groups.Count > 0)
        {
            <div style="margin-top:14px;">
                <span class="kv-label">Group Membership</span>
                <div class="chips">
                    @foreach (var g in Model.Groups)
                    {
                        <a class="chip" href="/Dashboard/Group?groupName=@Uri.EscapeDataString(g)">@g</a>
                    }
                </div>
            </div>
        }
    </div>

    <div class="card">
        <h3>Quick Actions</h3>
        <div class="helpdesk-quick-actions">
            <form method="post" action="/Dashboard/RunHelpdeskCommand" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetType" value="Device" />
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="CommandKey" value="CollectSystemInfo" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("system")</span><span>Collect System Info</span></button>
            </form>

            <!--<form method="post" action="/Dashboard/RunHelpdeskCommand" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetType" value="Device" />
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="CommandKey" value="NetworkInfo" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("network")</span><span>Network Info</span></button>
            </form>-->

            <form method="post" action="/Dashboard/IssueCommand" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="Type" value="CollectProcessStatus" />
                <input type="hidden" name="PayloadJson" value="{}" />
                <input type="hidden" name="Priority" value="100" />
                <input type="hidden" name="MaxAttempts" value="3" />
                <input type="hidden" name="UseCustomJson" value="true" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("process")</span><span>Collect Process Status</span></button>
            </form>

            <form method="post" action="/Dashboard/IssueCommand" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="Type" value="CollectSoftwareInventory" />
                <input type="hidden" name="PayloadJson" value="{}" />
                <input type="hidden" name="Priority" value="100" />
                <input type="hidden" name="MaxAttempts" value="3" />
                <input type="hidden" name="UseCustomJson" value="true" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("software")</span><span>Collect Software Inventory</span></button>
            </form>

            <form method="post" action="/Dashboard/RunHelpdeskCommand" class="inline" onsubmit="return confirm('Restart POS on @Model.Hostname?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetType" value="Device" />
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="CommandKey" value="RestartPOS" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("restart")</span><span>Restart POS</span></button>
            </form>

            <form method="post" action="/Dashboard/RunHelpdeskCommand" class="inline" onsubmit="return confirm('Reboot @Model.Hostname?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetType" value="Device" />
                <input type="hidden" name="DeviceId" value="@Model.DeviceId" />
                <input type="hidden" name="CommandKey" value="RebootDevice" />
                <button type="submit" class="btn btn-danger"><span class="icon-inline">@SvgIcon("reboot")</span><span>Reboot Device</span></button>
            </form>

            <form method="post" action="/Dashboard/RequeueRecentFailedCommands" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="deviceId" value="@Model.DeviceId" />
                <button type="submit" class="btn btn-secondary"><span class="icon-inline">@SvgIcon("requeue")</span><span>Requeue Failed Commands</span></button>
            </form>

            <form method="post" action="/Dashboard/RetireDevice" class="inline" onsubmit="return confirm('Retire this device?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="deviceId" value="@Model.DeviceId" />
                <button type="submit" class="btn btn-danger" @(Model.IsOnline ? "disabled" : null)><span class="icon-inline">@SvgIcon("retire")</span><span>Retire Device</span></button>
            </form>
        </div>
    </div>

    <div class="card">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:12px;">
            <h3 style="margin:0;">User Activity</h3>
            <span id="activity-status" class="@Model.UserActivityCssClass">@Model.UserActivityStatus</span>
        </div>

        @if (Model.UserActivity == null)
        {
            <div class="alert alert-warning">No user activity has been collected yet.</div>
        }
        else
        {
            <div class="kv-grid">
                <div class="kv-item"><span class="kv-label">Session State</span><span id="activity-session-state" class="kv-value">@Model.UserActivity.SessionStateDisplay</span></div>
                <div class="kv-item"><span class="kv-label">Console User</span><span id="activity-console-user" class="kv-value">@(Model.UserActivity.ConsoleUserName ?? "Unknown")</span></div>
                <div class="kv-item"><span class="kv-label">Idle Time</span><span id="idle-time" class="kv-value">@Model.UserActivity.IdleDisplay</span></div>
                <div class="kv-item"><span class="kv-label">User Active</span><span id="user-active" class="kv-value">@Model.UserActivity.IsUserActiveDisplay</span></div>
                <div class="kv-item"><span class="kv-label">POS Foreground</span><span id="pos-foreground" class="kv-value">@Model.UserActivity.PosForegroundDisplay</span></div>
                <div class="kv-item"><span class="kv-label">Idle Seconds</span><span id="idle-seconds" class="kv-value">@(Model.UserActivity.IdleSeconds?.ToString() ?? "Unknown")</span></div>
                <div class="kv-item"><span class="kv-label">Last Input</span><span id="last-input" class="kv-value">@(Model.UserActivity.LastInputUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "Unknown")</span></div>
                <div class="kv-item"><span class="kv-label">Captured</span><span id="activity-captured" class="kv-value">@(Model.UserActivity.CapturedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "Unknown")</span></div>
                <div class="kv-item"><span class="kv-label">Last Updated</span><span id="activity-updated" class="kv-value">@Model.UserActivity.UpdatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>
            </div>
        }
    </div>

    <div class="card">
        <h3>Process Status</h3>

        @if (Model.ProcessStatus == null)
        {
            <div class="alert alert-warning">No process status has been collected yet.</div>
        }
        else
        {
            var ps = Model.ProcessStatus;

            <div class="kv-grid">
                <div class="kv-item">
                    <span class="kv-label">Last Process Scan</span>
                    <span class="kv-value">@(ps.UpdatedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
                </div>
            </div>

            <div class="table-wrap" style="margin-top:12px;">
                <table>
                    <thead>
                        <tr>
                            <th>Application</th>
                            <th>Configured Name</th>
                            <th>Status</th>
                            <th>Count</th>
                            <th>Memory MB</th>
                            <th>Started</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>POS</td>
                            <td>@(ps.PosProcessName ?? "-")</td>
                            <td>
                                <span class="badge @(ps.PosRunning ? "badge-online" : "badge-offline")">
                                    @(ps.PosRunning ? "Running" : "Not Running")
                                </span>
                            </td>
                            <td>@ps.PosProcessCount</td>
                            <td>@(ps.PosWorkingSetMb?.ToString("0.##") ?? "-")</td>
                            <td>@(ps.PosStartedAtLocal?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        </tr>
                        <tr>
                            <td>RetailShell</td>
                            <td>@(ps.RetailShellProcessName ?? "-")</td>
                            <td>
                                <span class="badge @(ps.RetailShellRunning ? "badge-online" : "badge-offline")">
                                    @(ps.RetailShellRunning ? "Running" : "Not Running")
                                </span>
                            </td>
                            <td>@ps.RetailShellProcessCount</td>
                            <td>@(ps.RetailShellWorkingSetMb?.ToString("0.##") ?? "-")</td>
                            <td>@(ps.RetailShellStartedAtLocal?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        </tr>
                        <tr>
                            <td>Agent</td>
                            <td>@(ps.AgentProcessName ?? "-")</td>
                            <td>
                                <span class="badge @(ps.AgentRunning ? "badge-online" : "badge-offline")">
                                    @(ps.AgentRunning ? "Running" : "Not Running")
                                </span>
                            </td>
                            <td>@ps.AgentProcessCount</td>
                            <td>@(ps.AgentWorkingSetMb?.ToString("0.##") ?? "-")</td>
                            <td>@(ps.AgentStartedAtLocal?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card">
        <h3>Remote Shadow Session</h3>
        <p class="subtle">Use the installed RetailShadowHelper on the technician workstation to launch a one-click shadow session. This runs on the technician PC, not on the register.</p>

        @if (Model.CanLaunchRemoteAssistance)
        {
            var remoteCommandJson = JsonSerializer.Serialize(Model.RemoteAssistanceCommand ?? "");

            <div class="helpdesk-quick-actions">
                <a class="btn btn-primary" href="@protocolLaunchUrl">
                    <span class="icon-inline">@SvgIcon("shadow")</span><span>Launch Shadow Session</span>
                </a>

                <a class="btn btn-secondary" href="/downloads/RetailShadowHelper.msi">
                    <span class="icon-inline">@SvgIcon("download")</span><span>Install Helper Agent</span>
                </a>

                <button type="button"
                        class="btn btn-outline"
                        onclick='copyShadowCommand(@Html.Raw(remoteCommandJson))'>
                    <span class="icon-inline">@SvgIcon("copy")</span><span>Copy Shadow Session Command</span>
                </button>
            </div>

            <div class="form-text" style="margin-top:10px;">
                Install the helper one time on the technician workstation before using Launch Shadow Session.
            </div>

            <div class="mt-2">
                <label class="form-label">RetailShadowHelper Launch Link</label>
                <pre>@protocolLaunchUrl</pre>
            </div>

            <div class="mt-2">
                <label class="form-label">Shadow Session Command</label>
                <pre>@Model.RemoteAssistanceCommand</pre>
            </div>

            <div class="form-text">
                Launch Shadow Session uses the installed <strong>RetailShadowHelper</strong> custom protocol on the technician PC. The helper link and command prefer the device IP address when available to avoid DHCP and name resolution issues.
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                No hostname or IP is available for a Remote Desktop Shadow session.
            </div>
        }
    </div>

    <div class="card">
        <h3>Software Inventory</h3>

        <div class="kv-grid" style="margin-bottom:14px;">
            <div class="kv-item">
                <span class="kv-label">Last Software Scan</span>
                <span class="kv-value">@(Model.LastSoftwareInventoryUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
            </div>
            <div class="kv-item">
                <span class="kv-label">Installed Software Count</span>
                <span class="kv-value">@Model.InstalledSoftware.Count</span>
            </div>
            <div class="kv-item">
                <span class="kv-label">Windows Update Count</span>
                <span class="kv-value">@Model.InstalledWindowsUpdates.Count</span>
            </div>
        </div>

        <h4 style="margin-top:18px;">Installed Software</h4>

        @if (Model.InstalledSoftware.Count == 0)
        {
            <div class="alert alert-warning">No installed software inventory has been collected yet.</div>
        }
        else
        {
            var softwareTop = Model.InstalledSoftware.Take(10).ToList();
            var softwareRemaining = Model.InstalledSoftware.Skip(10).ToList();

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Version</th>
                            <th>Publisher</th>
                            <th>Install Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in softwareTop)
                        {
                            <tr>
                                <td>@(item.Name ?? "-")</td>
                                <td>@(item.Version ?? "-")</td>
                                <td>@(item.Publisher ?? "-")</td>
                                <td>@(item.InstallDate ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (softwareRemaining.Count > 0)
            {
                <details style="margin-top:12px;">
                    <summary style="cursor:pointer; font-weight:600;">
                        Show remaining @softwareRemaining.Count software entries
                    </summary>

                    <div class="table-wrap" style="margin-top:12px;">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Version</th>
                                    <th>Publisher</th>
                                    <th>Install Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in softwareRemaining)
                                {
                                    <tr>
                                        <td>@(item.Name ?? "-")</td>
                                        <td>@(item.Version ?? "-")</td>
                                        <td>@(item.Publisher ?? "-")</td>
                                        <td>@(item.InstallDate ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </details>
            }
        }

        <h4 style="margin-top:22px;">Windows Updates</h4>

        @if (Model.InstalledWindowsUpdates.Count == 0)
        {
            <div class="alert alert-warning">No Windows update inventory has been collected yet.</div>
        }
        else
        {
            var updatesTop = Model.InstalledWindowsUpdates.Take(10).ToList();
            var updatesRemaining = Model.InstalledWindowsUpdates.Skip(10).ToList();

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>HotFix ID</th>
                            <th>Description</th>
                            <th>Installed On</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in updatesTop)
                        {
                            <tr>
                                <td>@(item.HotFixId ?? "-")</td>
                                <td>@(item.Description ?? "-")</td>
                                <td>@(item.InstalledOn ?? "-")</td>
                            </tr>
