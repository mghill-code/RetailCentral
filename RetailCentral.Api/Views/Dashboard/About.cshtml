@model RetailCentral.Api.ViewModels.AboutPageConfig

@{
    ViewData["Title"] = "About";
}

<div class="page-header">
    <div>
        <h1>About</h1>
        <p>Product identity, mission, support ownership, and platform details.</p>
    </div>
</div>

<div style="display:grid; grid-template-columns: 2fr 1fr; gap:16px; align-items:stretch;">
    <div class="card" style="padding:24px;">
        <div class="subtle" style="text-transform:uppercase; letter-spacing:.08em; font-weight:700; margin-bottom:10px;">Product</div>
        <h1 style="margin:0 0 8px 0; font-size:2.25rem;">@Model.ProductName</h1>
        <div class="subtle" style="font-size:1.05rem; margin-bottom:18px;">@Model.Subtitle</div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:18px;">
            <span class="badge badge-pending" style="font-size:.95rem; padding:8px 12px;">@Model.Acronym</span>
            <span class="subtle" style="display:flex; align-items:center;">@Model.AcronymExpansion</span>
        </div>

        <div style="margin-top:10px;">
            <div style="font-weight:700; margin-bottom:8px;">Platform Mission</div>
            <p style="margin:0; max-width:900px;">@Model.Mission</p>
        </div>
    </div>

    <div style="display:grid; grid-template-rows: 1fr 1fr; gap:16px;">
        <div class="card metric-card progress-card">
            <div class="metric-label">Environment</div>
            <div class="metric-value">@Model.Environment.DisplayName</div>
        </div>

        <div class="card" style="padding:20px;">
            <div class="metric-label" style="margin-bottom:10px;">Support Ownership</div>
            <div style="display:grid; gap:10px;">
                <div>
                    <div class="subtle" style="font-weight:700;">Primary Owner</div>
                    <div>@Model.Support.PrimaryOwner</div>
                </div>
                <div>
                    <div class="subtle" style="font-weight:700;">Support Team</div>
                    <div>@Model.Support.SupportTeam</div>
                </div>
                <div>
                    <div class="subtle" style="font-weight:700;">Escalation</div>
                    <div>@Model.Support.Escalation</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns: 1.2fr 1fr; gap:16px; margin-top:16px;">
    <div class="card" style="padding:20px;">
        <h3 style="margin-top:0;">Core Capabilities</h3>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px 18px;">
            @foreach (var capability in Model.Capabilities)
            {
                <div style="display:flex; align-items:flex-start; gap:10px;">
                    <span style="font-weight:700; color:var(--accent, #2563eb);">•</span>
                    <span>@capability</span>
                </div>
            }
        </div>
    </div>

    <div class="card" style="padding:20px;">
        <h3 style="margin-top:0;">Product Summary</h3>
        <p style="margin-bottom:0;">@Model.PlatformSummary</p>
    </div>
</div>

<div class="card" style="margin-top:16px;">
    <h3>Environment / Version</h3>
    <div class="table-wrap">
        <table>
            <tbody>
                <tr>
                    <th style="width:28%;">Environment</th>
                    <td>@Model.Environment.DisplayName</td>
                </tr>

                @if (Model.Environment.ShowRuntimeDetails)
                {
                    <tr>
                        <th>Application Version</th>
                        <td>@(System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "Unknown")</td>
                    </tr>
                    <tr>
                        <th>Runtime</th>
                        <td>@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</td>
                    </tr>
                    <tr>
                        <th>Host</th>
                        <td>@Environment.MachineName</td>
                    </tr>
                    <tr>
                        <th>Current UTC</th>
                        <td>@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>