@model IEnumerable<RetailCentral.Api.ViewModels.CommandSummaryViewModel>

@{
    ViewData["Title"] = "Failures";
}

<div class="page-header">
    <div>
        <h1>Failed Commands</h1>
        <p>Review commands that failed execution and open detail for logs and remediation.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="/Dashboard/Commands">📜 All Commands</a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:24%;">Command</th>
                    <th style="width:16%;">Type</th>
                    <th style="width:12%;">Status</th>
                    <th style="width:12%;">Scope</th>
                    <th style="width:10%;">Store</th>
                    <th style="width:26%;">Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><a href="/Dashboard/Command/@c.CommandId"><strong>@c.CommandId</strong></a></td>
                        <td>@c.Type</td>
                        <td><span class="badge badge-failed">@c.Status</span></td>
                        <td>@c.Scope</td>
                        <td>@c.StoreNumber</td>
                        <td>@c.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
