@model RetailCentral.Api.Models.Dashboard.Deployments.DeploymentDetailsViewModel

@{
    ViewData["Title"] = "Deployment Detail";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Deployment #@Model.Id</h1>
        <p>Deployment targeting, package details, and device status.</p>
    </div>

    <div class="page-actions">
        <a asp-action="Deployments" class="btn btn-secondary">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
            </span>
            Back
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Summary</h5>

                <div class="mb-2"><strong>Status:</strong> @Model.Status</div>
                <div class="mb-2"><strong>Package:</strong> @Model.PackageName</div>

                @if (!string.IsNullOrWhiteSpace(Model.PackageVersion))
                {
                    <div class="mb-2"><strong>Package Version:</strong> @Model.PackageVersion</div>
                }

                <div class="mb-2"><strong>Target Type:</strong> @Model.TargetType</div>
                <div class="mb-2"><strong>Target Value:</strong> @Model.TargetValue</div>
                <div class="mb-2"><strong>Execute Mode:</strong> @Model.ExecuteMode</div>
                <div class="mb-2"><strong>Created:</strong> @Model.CreatedUtc.ToLocalTime().ToString("g")</div>

                @if (!string.IsNullOrWhiteSpace(Model.CreatedBy))
                {
                    <div class="mb-2"><strong>Created By:</strong> @Model.CreatedBy</div>
                }

                @if (Model.WindowStartLocal.HasValue || Model.WindowEndLocal.HasValue)
                {
                    <div class="mb-2">
                        <strong>Window:</strong>
                        @(Model.WindowStartLocal?.ToString(@"hh\:mm") ?? "—")
                        -
                        @(Model.WindowEndLocal?.ToString(@"hh\:mm") ?? "—")
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <div class="mt-3">
                        <strong>Notes:</strong>
                        <div class="text-muted mt-1">@Model.Notes</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Device Results</h5>

                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Device</th>
                                <th>Status</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.DeviceRows)
                            {
                                <tr>
                                    <td>@row</td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.DeviceRows == null || Model.DeviceRows.Count == 0)
                {
                    <div class="text-muted">No device rows were returned for this deployment.</div>
                }
            </div>
        </div>
    </div>
</div>