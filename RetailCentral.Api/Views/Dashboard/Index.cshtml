@model RetailCentral.Api.ViewModels.DashboardIndexViewModel

@{
    ViewData["Title"] = "Device Control Center";
}

<div class="page-header">
    <div class="page-heading-copy">
        <h1>RetailCommand</h1>
        <p>Device Control Center for operational visibility across device health, command activity, deployments, version mix, and store-level exceptions.</p>
    </div>
    <div class="page-actions">
        <a class="btn has-icon" href="/Dashboard/CreateDeployment">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 5v14" /><path d="M5 12h14" /><path d="M5 5h14v14H5z" /></svg>
            </span>
            <span class="btn-label">New Deployment</span>
        </a>
        <a class="btn btn-secondary has-icon" href="/Dashboard/IssueCommand">
            <span class="action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 19l7 -7l-3 -3l-7 7l-1 4z" /><path d="M16 5l3 3" /></svg>
            </span>
            <span class="btn-label">Issue Command</span>
        </a>
    </div>
</div>

<div class="grid">
    <a href="/Dashboard/Devices?status=Active" class="metric-card-link">
        <div class="card metric-card online-card">
            <div class="metric-label">Total Devices</div>
            <div class="metric-value">@Model.TotalDevices</div>
            <div class="metric-footnote">Registered active devices in inventory</div>
        </div>
    </a>
    <a href="/Dashboard/Devices?status=Online" class="metric-card-link">
        <div class="card metric-card success-card">
            <div class="metric-label">Online</div>
            <div class="metric-value online">@Model.OnlineDevices</div>
            <div class="metric-footnote">Heartbeat within the last 5 minutes</div>
        </div>
    </a>
    <a href="/Dashboard/Devices?status=Offline" class="metric-card-link">
        <div class="card metric-card failed-card">
            <div class="metric-label">Offline</div>
            <div class="metric-value offline">@Model.OfflineDevices</div>
            <div class="metric-footnote">Requires follow-up or store outreach</div>
        </div>
    </a>

    <a asp-action="Commands" asp-controller="Dashboard" asp-route-status="Pending" class="card metric-card pending-card metric-card-link">
        <div class="metric-label">Pending Commands</div>
        <div class="metric-value pending">@Model.CommandsPending</div>
        <div class="metric-footnote">Queued and waiting for agent pickup</div>
    </a>
    <a asp-action="Commands" asp-controller="Dashboard" asp-route-status="InProgress" class="card metric-card progress-card metric-card-link">
        <div class="metric-label">Commands In Progress</div>
        <div class="metric-value inprogress">@Model.CommandsInProgress</div>
        <div class="metric-footnote">Currently locked by active agents</div>
    </a>
    <a asp-action="Commands" asp-controller="Dashboard" asp-route-status="Failed" class="card metric-card failed-card metric-card-link">
        <div class="metric-label">Commands Failed (24h)</div>
        <div class="metric-value offline">@Model.CommandsFailedLast24Hours</div>
        <div class="metric-footnote">Recent failures requiring review</div>
    </a>
    <a asp-action="Commands" asp-controller="Dashboard" asp-route-status="Succeeded" class="card metric-card success-card metric-card-link">
        <div class="metric-label">Commands Succeeded (24h)</div>
        <div class="metric-value online">@Model.CommandsSucceededLast24Hours</div>
        <div class="metric-footnote">Successful work completed today</div>
    </a>
    <div class="card metric-card warning-card">
        <div class="metric-label">Critical Health</div>
        <div class="metric-value">@Model.CriticalDevices</div>
        <div class="metric-footnote">Devices scoring below warning threshold</div>
    </div>
</div>

<div class="dashboard-stack">
    <div class="card">
        <h3>Fleet Heatmap</h3>
        <p class="card-subtle">Sample of recently seen devices by severity.</p>
        <div class="heatmap">
            @foreach (var tile in Model.DeviceHeatmap)
            {
                <a href="/Dashboard/Device/@tile.DeviceId" class="heatmap-link">
                    <div class="heatmap-tile heat-@tile.Severity">
                        <div><strong>@tile.Hostname</strong></div>
                        <div class="subtle">Store @tile.StoreNumber</div>
                        <div style="margin-top:8px;">
                            <span class="badge @(tile.IsOnline ? "badge-online" : "badge-offline")">
                                @(tile.IsOnline ? "Online" : "Offline")
                            </span>
                        </div>
                        <div class="subtle" style="margin-top:8px;">
                            Last seen: @tile.LastSeenUtc.ToString("yyyy-MM-dd HH:mm:ss")
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>

    <div class="grid-2">
        <div class="card">
            <h3>Online vs Offline</h3>
            <p class="card-subtle">Current heartbeat-based device availability.</p>
            <div class="chart-box">
                <canvas id="deviceChart"></canvas>
            </div>
        </div>

    <div class="card">
        <h3>Version Mix</h3>
        <p class="card-subtle">Top agent versions in the fleet.</p>
        <div class="chart-box">
            <canvas id="versionChart"></canvas>
        </div>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3>Command Progress</h3>
        @foreach (var p in Model.CommandProgress)
        {
            <div style="margin-bottom:14px;">
                <div class="toolbar-card" style="margin-bottom:6px;">
                    <div><strong>@p.Label</strong></div>
                    <div class="subtle">@p.Count of @p.Total (@p.Percent%)</div>
                </div>
                <div class="progress">
                    <div class="progress-bar @p.CssClass" style="width:@p.Percent%;"></div>
                </div>
            </div>
        }
    </div>

    <div class="card">
        <h3>Device Health Mix</h3>
        <div class="status-list">
            <div class="kv-item"><span class="kv-label">Healthy</span><span class="kv-value online">@Model.HealthyDevices</span></div>
            <div class="kv-item"><span class="kv-label">Warning</span><span class="kv-value pending">@Model.WarningDevices</span></div>
            <div class="kv-item"><span class="kv-label">Critical</span><span class="kv-value offline">@Model.CriticalDevices</span></div>
            <div class="kv-item"><span class="kv-label">Stores with issues</span><span class="kv-value">@Model.StoreOutages.Count</span></div>
        </div>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3>Recent Devices</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Store</th>
                        <th>Hostname</th>
                        <th>Status</th>
                        <th>Version</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.RecentDevices)
                    {
                        <tr>
                            <td>@d.StoreNumber</td>
                            <td><a href="/Dashboard/Device/@d.DeviceId">@d.Hostname</a></td>
                            <td><span class="badge @(d.IsOnline ? "badge-online" : "badge-offline")">@(d.IsOnline ? "Online" : "Offline")</span></td>
                            <td>@(string.IsNullOrWhiteSpace(d.AgentVersion) ? "-" : d.AgentVersion)</td>
                            <td>@d.LastSeenUtc?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <h3>Recent Commands</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Command</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Scope</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.RecentCommands)
                    {
                        var statusCss = c.Status?.ToLower() switch
                        {
                            "succeeded" => "badge-succeeded",
                            "failed" => "badge-failed",
                            "pending" => "badge-pending",
                            "inprogress" => "badge-inprogress",
                            _ => "badge-muted"
                        };
                        <tr>
                            <td><a href="/Dashboard/Command/@c.CommandId">@c.CommandId</a></td>
                            <td>@c.Type</td>
                            <td><span class="badge @statusCss">@c.Status</span></td>
                            <td>@c.Scope</td>
                            <td>@c.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3>Top Agent Versions</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Version</th>
                        <th>Total</th>
                        <th>Online</th>
                        <th>Offline</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.VersionSummary.Take(10))
                    {
                        <tr>
                            <td>@v.AgentVersion</td>
                            <td>@v.DeviceCount</td>
                            <td class="online">@v.OnlineCount</td>
                            <td class="offline">@v.OfflineCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <h3>Stores with Outages or Offline Devices</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Store</th>
                        <th>Total Devices</th>
                        <th>Offline</th>
                        <th>Condition</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.StoreOutages)
                    {
                        <tr>
                            <td>@s.StoreNumber</td>
                            <td>@s.TotalDevices</td>
                            <td class="offline">@s.OfflineDevices</td>
                            <td>
                                <span class="badge @(s.IsOutage ? "badge-failed" : "badge-pending")">
                                    @(s.IsOutage ? "Store Outage" : "Partial Impact")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            const deviceCanvas = document.getElementById("deviceChart");
            const versionCanvas = document.getElementById("versionChart");

            if (deviceCanvas) {
                const deviceCtx = deviceCanvas.getContext("2d");

                new Chart(deviceCtx, {
                    type: "doughnut",
                    data: {
                        labels: ["Online", "Offline"],
                        datasets: [{
                            data: [@Model.OnlineDevices, @Model.OfflineDevices],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: "top"
                            }
                        }
                    }
                });
            }

            if (versionCanvas) {
                const versionCtx = versionCanvas.getContext("2d");

                new Chart(versionCtx, {
                    type: "bar",
                    data: {
                        labels: [
                            @Html.Raw(string.Join(",", Model.VersionSummary.Take(10).Select(v => $"'{v.AgentVersion ?? "Unknown"}'")))
                        ],
                        datasets: [{
                            label: "Devices",
                            data: [
                                @string.Join(",", Model.VersionSummary.Take(10).Select(v => v.DeviceCount))
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }
        })();
    </script>
}
