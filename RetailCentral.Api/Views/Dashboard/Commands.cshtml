@model RetailCentral.Api.ViewModels.CommandCenterViewModel

@{
    ViewData["Title"] = "Command Center";
}

@if (TempData["CommandMessage"] != null)
{
    <div class="alert alert-info">@TempData["CommandMessage"]</div>
}

<div class="page-header">
    <div>
        <h1>Command Center</h1>
        <p>Filter, review, and clean up queued and completed commands.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="IssueCommand">
            <span class="action-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14" />
                    <path d="M5 12h14" />
                </svg>
            </span>
            Issue Command
        </a>
    </div>
</div>

<div class="stats-grid command-stats-grid">
    <a asp-action="Commands"
       class="stat-card stat-card-link stat-card-neutral @(string.IsNullOrWhiteSpace(Model.Status) && !Model.ShowExpiredPendingOnly ? "active" : "")">
        <div class="stat-label">Total</div>
        <div class="stat-value">@Model.TotalCount</div>
    </a>

    <a asp-action="Commands"
       asp-route-status="Pending"
       class="stat-card stat-card-link stat-card-warning @(Model.Status == "Pending" && !Model.ShowExpiredPendingOnly ? "active" : "")">
        <div class="stat-label">Pending</div>
        <div class="stat-value pending">@Model.PendingCount</div>
    </a>

    <a asp-action="Commands"
       asp-route-status="InProgress"
       class="stat-card stat-card-link stat-card-info @(Model.Status == "InProgress" ? "active" : "")">
        <div class="stat-label">In Progress</div>
        <div class="stat-value inprogress">@Model.InProgressCount</div>
    </a>

    <a asp-action="Commands"
       asp-route-status="Failed"
       class="stat-card stat-card-link stat-card-danger @(Model.Status == "Failed" ? "active" : "")">
        <div class="stat-label">Failed</div>
        <div class="stat-value offline">@Model.FailedCount</div>
    </a>

    <a asp-action="Commands"
       asp-route-status="Succeeded"
       class="stat-card stat-card-link stat-card-success @(Model.Status == "Succeeded" ? "active" : "")">
        <div class="stat-label">Succeeded</div>
        <div class="stat-value online">@Model.SucceededCount</div>
    </a>

    <a asp-action="Commands"
       asp-route-expiredPendingOnly="true"
       class="stat-card stat-card-link stat-card-danger-soft @(Model.ShowExpiredPendingOnly ? "active" : "")">
        <div class="stat-label">Expired Pending</div>
        <div class="stat-value">@Model.ExpiredPendingCount</div>
    </a>
</div>

<div class="card command-filter-card">
    <form method="get" asp-action="Commands" class="command-filter-grid">
        <div>
            <label class="form-label">Status</label>
            <select name="status" class="form-select dashboard-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status) ? "selected" : null)">All</option>
                <option value="Pending" selected="@(Model.Status == "Pending" ? "selected" : null)">Pending</option>
                <option value="InProgress" selected="@(Model.Status == "InProgress" ? "selected" : null)">In Progress</option>
                <option value="Failed" selected="@(Model.Status == "Failed" ? "selected" : null)">Failed</option>
                <option value="Succeeded" selected="@(Model.Status == "Succeeded" ? "selected" : null)">Succeeded</option>
                <option value="Canceled" selected="@(Model.Status == "Canceled" ? "selected" : null)">Canceled</option>
            </select>
        </div>

        <div>
            <label class="form-label">Search</label>
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Type, store, group, issued by, payload..." />
        </div>

        <div class="form-check command-filter-check">
            <input class="form-check-input" type="checkbox" id="expiredPendingOnly" name="expiredPendingOnly" value="true" @(Model.ShowExpiredPendingOnly ? "checked" : null) />
            <label class="form-check-label" for="expiredPendingOnly">Expired pending only</label>
        </div>

        <div class="command-filter-actions">
            <button type="submit" class="btn">Apply</button>
            <a class="btn btn-secondary" asp-action="Commands">Reset</a>
        </div>
    </form>
</div>

@if (Model.ExpiredPendingCount > 0)
{
    <div class="card command-alert-card">
        <div>
            <h3>Expired pending commands detected</h3>
            <p>These commands will never run because their expiration window already passed.</p>
        </div>
        <form method="post" asp-action="FailExpiredPendingCommands" class="inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Mark All Expired Pending Failed</button>
        </form>
    </div>
}

<div class="card">
    <div class="section-heading">
        <h3>Command Queue</h3>
        <p>Review status, scope, expiration, errors, and retry history.</p>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:14%;">Created</th>
                    <th style="width:14%;">Type</th>
                    <th style="width:12%;">Status</th>
                    <th style="width:10%;">Scope</th>
                    <th style="width:8%;">Store</th>
                    <th style="width:16%;">Device / Group</th>
                    <th style="width:12%;">Expires</th>
                    <th style="width:18%;">Reason / Last Error</th>
                    <th style="width:8%;">Attempts</th>
                    <th style="width:8%;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Commands.Count == 0)
                {
                    <tr>
                        <td colspan="10" class="empty-state">No commands found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var c in Model.Commands)
                    {
                        var statusCss = c.IsExpiredPending ? "badge-danger" : c.Status?.ToLower() switch
                        {
                            "succeeded" => "badge-succeeded",
                            "failed" => "badge-failed",
                            "pending" => "badge-pending",
                            "inprogress" => "badge-inprogress",
                            _ => "badge-muted"
                        };

                        <tr>
                            <td>@c.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                <div><a href="/Dashboard/Command/@c.CommandId"><strong>@c.Type</strong></a></div>
                                <div class="subtle command-id-row">@c.CommandId</div>
                            </td>
                            <td>
                                <span class="badge @statusCss">@(c.IsExpiredPending ? "Expired Pending" : c.Status)</span>
                            </td>
                            <td>@c.Scope</td>
                            <td>@(string.IsNullOrWhiteSpace(c.StoreNumber) ? "-" : c.StoreNumber)</td>
                            <td>
                                @if (c.DeviceId != null)
                                {
                                    <div class="command-target-text">@c.DeviceId</div>
                                }
                                else if (!string.IsNullOrWhiteSpace(c.GroupName))
                                {
                                    <div class="command-target-text">@c.GroupName</div>
                                }
                                else
                                {
                                    <span class="subtle">n/a</span>
                                }
                            </td>
                            <td>@(c.ExpiresUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(c.LastError))
                                {
                                    <div>@c.LastError</div>
                                }
                                else if (c.Status == "Pending")
                                {
                                    <div>@c.PendingReason</div>
                                }
                                else
                                {
                                    <span class="subtle">-</span>
                                }
                            </td>
                            <td>@c.AttemptCount / @c.MaxAttempts</td>
                            <td>
                                @if (c.IsExpiredPending)
                                {
                                    <form method="post" asp-action="FailExpiredPendingCommand" asp-route-id="@c.CommandId" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger command-inline-btn">Fail</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="subtle">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
