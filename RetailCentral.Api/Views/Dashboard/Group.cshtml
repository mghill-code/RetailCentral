@model RetailCentral.Api.ViewModels.GroupDetailViewModel

@{
    ViewData["Title"] = "Group Detail";
}

<h2>Group: @Model.GroupName</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="card" style="margin-bottom:16px;">
        <div>@Model.Message</div>
    </div>
}

<div class="grid-2">
    <div class="card">
        <h3>Group Details</h3>

        <div><strong>Name:</strong> @Model.GroupName</div>
        <div><strong>Description:</strong> @(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</div>
        <div><strong>Created:</strong> @Model.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
        <div><strong>Members:</strong> @Model.Members.Count</div>

        <div class="action-row" style="margin-top:16px;">
            <form method="post" action="/Dashboard/DeleteGroup"
                  onsubmit="return confirm('Delete group @Model.GroupName? Group must be empty first.');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="groupName" value="@Model.GroupName" />
                <button type="submit" class="btn btn-danger">Delete Group</button>
            </form>
        </div>
    </div>

    <div class="card">
        <h3>Add Device to Group</h3>

        <form method="post" action="/Dashboard/AddDeviceToGroup">
            @Html.AntiForgeryToken()
            <input type="hidden" name="groupName" value="@Model.GroupName" />

            <div>
                <label>Available Devices</label>
                <select name="deviceId">
                    @foreach (var d in Model.AvailableDevices)
                    {
                        <option value="@d.DeviceId">
                            @d.StoreNumber - @d.Hostname @(d.IsOnline ? "(Online)" : "(Offline)")
                        </option>
                    }
                </select>
            </div>

            <div class="action-row" style="margin-top:12px;">
                <button type="submit">Add Device</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <h3>CSV Import Help</h3>
    <p class="subtle">
        To bulk add members, go back to the Groups page and use the CSV import section.
    </p>
    <p class="subtle">
        Recommended format:
    </p>
<pre>StoreNumber,Hostname
1001,POS01
1001,POS02
1002,POS03</pre>
</div>

<div class="card">
    <h3>Group Members</h3>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:15%;">Store</th>
                    <th style="width:35%;">Hostname</th>
                    <th style="width:15%;">Status</th>
                    <th style="width:20%;">Version</th>
                    <th style="width:15%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Members)
                {
                    <tr>
                        <td>@d.StoreNumber</td>
                        <td>
                            <a href="/Dashboard/Device/@d.DeviceId">@d.Hostname</a>
                        </td>
                        <td>
                            <span class="badge @(d.IsOnline ? "badge-online" : "badge-offline")">
                                @(d.IsOnline ? "Online" : "Offline")
                            </span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(d.AgentVersion) ? "-" : d.AgentVersion)</td>
                        <td>
                            <form method="post" action="/Dashboard/RemoveDeviceFromGroup"
                                  onsubmit="return confirm('Remove @d.Hostname from @Model.GroupName?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="groupName" value="@Model.GroupName" />
                                <input type="hidden" name="deviceId" value="@d.DeviceId" />
                                <button type="submit" class="btn btn-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>