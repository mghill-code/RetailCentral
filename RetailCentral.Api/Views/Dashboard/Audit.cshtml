@model RetailCentral.Api.ViewModels.AuditViewModel

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="page-header">
    <div>
        <h1>Audit Logs</h1>
        <p>Search, review, and export administrative and operational activity across RetailCentral.</p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2>Filters</h2>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Audit" asp-controller="Dashboard">
            <div style="display:grid; grid-template-columns: repeat(4, minmax(220px, 1fr)); gap:16px;">
                <div>
                    <label><strong>User</strong></label>
                    <input name="UserName" type="text" value="@Model.UserName" />
                </div>

                <div>
                    <label><strong>Action</strong></label>
                    <input name="ActionName" type="text" value="@Model.ActionName" />
                </div>

                <div>
                    <label><strong>Target Type</strong></label>
                    <input name="TargetType" type="text" value="@Model.TargetType" />
                </div>

                <div>
                    <label><strong>Target Id</strong></label>
                    <input name="TargetId" type="text" value="@Model.TargetId" />
                </div>

                <div>
                    <label><strong>From</strong></label>
                    <input name="FromUtc" type="datetime-local"
                           value="@(Model.FromUtc?.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>

                <div>
                    <label><strong>To</strong></label>
                    <input name="ToUtc" type="datetime-local"
                           value="@(Model.ToUtc?.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>

                <div>
                    <label><strong>Result</strong></label>
                    <select name="Success">
                        <option value="">-- All --</option>
                        <option value="true" selected="@(Model.Success == true)">Success</option>
                        <option value="false" selected="@(Model.Success == false)">Failed</option>
                    </select>
                </div>
            </div>

            <div style="margin-top:16px; display:flex; gap:12px; flex-wrap:wrap;">
                <button type="submit" class="btn">Filter</button>
                <a class="btn btn-secondary" asp-action="Audit">Clear</a>
                <a class="btn btn-secondary"
                   asp-action="ExportAudit"
                   asp-route-UserName="@Model.UserName"
                   asp-route-ActionName="@Model.ActionName"
                   asp-route-TargetType="@Model.TargetType"
                   asp-route-TargetId="@Model.TargetId"
                   asp-route-FromUtc="@(Model.FromUtc?.ToString("o"))"
                   asp-route-ToUtc="@(Model.ToUtc?.ToString("o"))"
                   asp-route-Success="@Model.Success">
                    Export CSV
                </a>
            </div>
        </form>
    </div>
</div>

<!-- 🔥 CLICKABLE METRIC CARDS -->
<div class="grid-3" style="margin-top:16px;">
    <a asp-action="Audit"
       class="metric-card-link @(Model.Success == null ? "active" : "")">
        <div class="card metric-card progress-card">
            <div class="metric-label">Total Rows Returned</div>
            <div class="metric-value">@Model.TotalRowsReturnedCount</div>
        </div>
    </a>

    <a asp-action="Audit"
       asp-route-Success="true"
       class="metric-card-link @(Model.Success == true ? "active" : "")">
        <div class="card metric-card success-card">
            <div class="metric-label">Successful</div>
            <div class="metric-value">@Model.SuccessfulCount</div>
        </div>
    </a>

    <a asp-action="Audit"
       asp-route-Success="false"
       class="metric-card-link @(Model.Success == false ? "active" : "")">
        <div class="card metric-card failed-card">
            <div class="metric-label">Failed</div>
            <div class="metric-value">@Model.FailedCount</div>
        </div>
    </a>
</div>

<div class="card" style="margin-top:16px;">
    <h3>Audit Results</h3>
    <div class="table-wrap">
        <table class="table audit-table">
            <thead>
                <tr>
                    <th>Time (UTC)</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Target</th>
                    <th>Result</th>
                    <th>IP Address</th>
                    <th>Error</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Results.Any())
                {
                    <tr>
                        <td colspan="8">No audit records found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Results)
                    {
                        <tr>
                            <td>@row.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@row.UserName</td>
                            <td>@row.Action</td>
                            <td>
                                <div>@row.TargetType</div>
                                <div class="subtle">@row.TargetId</div>
                            </td>
                            <td>
                                @if (row.Success)
                                {
                                    <span class="badge badge-succeeded">Success</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Failed</span>
                                }
                            </td>
                            <td>@row.IpAddress</td>
                            <td>
                                @(string.IsNullOrWhiteSpace(row.ErrorMessage) ? "—" : row.ErrorMessage)
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(row.Details))
                                {
                                    <span class="subtle">—</span>
                                }
                                else
                                {
                                    <details>
                                        <summary>View</summary>
                                        <pre>@row.Details</pre>
                                    </details>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.body.setAttribute("data-no-autorefresh", "true");
    </script>
}