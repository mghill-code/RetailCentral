@model RetailCentral.Api.ViewModels.Orchestration.EditOrchestrationTemplateStepViewModel

@{
    ViewData["Title"] = ViewData["Title"] ?? "Orchestration Step";
    var formAction = ViewData["FormAction"]?.ToString() ?? "CreateOrchestrationTemplateStep";
    var submitText = ViewData["SubmitText"]?.ToString() ?? "Save";
}

<div class="page-header">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>Template: @Model.TemplateName</p>
    </div>
    <div class="page-actions">
        <a asp-action="OrchestrationTemplate" asp-route-id="@Model.TemplateId" class="btn btn-outline">Back to Template</a>
    </div>
</div>

<div class="card">
    <form asp-action="@formAction" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="form-grid">
        @Html.AntiForgeryToken()
        <input asp-for="TemplateId" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="field">
            <label asp-for="StepOrder"></label>
            <input asp-for="StepOrder" type="number" min="1" />
            <span asp-validation-for="StepOrder" class="text-danger"></span>
        </div>

        <div class="field">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="field">
            <label asp-for="StepType"></label>
            <select asp-for="StepType" asp-items="Model.StepTypeOptions" class="dashboard-select" id="stepTypeSelect">
                <option value="">Select step type...</option>
            </select>
            <span asp-validation-for="StepType" class="text-danger"></span>
            <div class="cell-secondary" style="margin-top:6px;" id="stepTypeDescription">
                @Model.StepTypeDescription
            </div>
        </div>

        <div class="field">
            <label asp-for="CommandType"></label>

            <select asp-for="CommandType" asp-items="Model.CommandTypeOptions" class="dashboard-select" id="commandTypeSelect">
                <option value="">Select command type...</option>
            </select>

            <input asp-for="CommandType" type="hidden" id="commandTypeHidden" disabled />

            <span asp-validation-for="CommandType" class="text-danger"></span>

            <div class="cell-secondary" style="margin-top:6px;" id="commandTypeDescription">
                @Model.GuidedParameterDescription
            </div>
        </div>

        <div class="field field-full" id="validateProcessField">
            <label asp-for="ValidateProcessName"></label>
            <input asp-for="ValidateProcessName" placeholder="Example: bncpos" id="validateProcessNameInput" />
            <span asp-validation-for="ValidateProcessName" class="text-danger"></span>
        </div>

        <div class="field field-full" id="validateRegistryFields">
            <div class="grid-2">
                <div class="field">
                    <label asp-for="ValidateRegistryHive"></label>
                    <select asp-for="ValidateRegistryHive" asp-items="Model.ValidateRegistryHiveOptions" class="dashboard-select" id="validateRegistryHiveSelect">
                        <option value="">Select hive...</option>
                    </select>
                    <span asp-validation-for="ValidateRegistryHive" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="ValidateRegistryValueName"></label>
                    <input asp-for="ValidateRegistryValueName" id="validateRegistryValueNameInput" />
                    <span asp-validation-for="ValidateRegistryValueName" class="text-danger"></span>
                </div>
            </div>

            <div class="field field-full">
                <label asp-for="ValidateRegistryKeyPath"></label>
                <input asp-for="ValidateRegistryKeyPath" placeholder="SOFTWARE\RetailCentral\Test" id="validateRegistryKeyPathInput" />
                <span asp-validation-for="ValidateRegistryKeyPath" class="text-danger"></span>
            </div>

            <div class="field field-full">
                <label asp-for="ValidateRegistryExpectedValue"></label>
                <input asp-for="ValidateRegistryExpectedValue" id="validateRegistryExpectedValueInput" />
                <span asp-validation-for="ValidateRegistryExpectedValue" class="text-danger"></span>
            </div>

            <div class="cell-secondary" style="margin-top:8px;">
                ValidateRegistry checks that a registry value exists and matches the expected value.
            </div>
        </div>

        <div class="field field-full" id="installPackageFields">
            <div class="grid-2">
                <div class="field">
                    <label asp-for="InstallPackageId"></label>
                    <select asp-for="InstallPackageId" asp-items="Model.InstallPackageOptions" class="dashboard-select" id="installPackageIdSelect">
                        <option value="">Select a package...</option>
                    </select>
                    <span asp-validation-for="InstallPackageId" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="InstallPackageExecuteMode"></label>
                    <select asp-for="InstallPackageExecuteMode" asp-items="Model.InstallPackageExecuteModeOptions" class="dashboard-select" id="installPackageExecuteModeSelect">
                        <option value="">Select execute mode...</option>
                    </select>
                    <span asp-validation-for="InstallPackageExecuteMode" class="text-danger"></span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.SelectedPackageSummary))
            {
                <div class="cell-secondary" style="margin-top:8px;">
                    @Model.SelectedPackageSummary
                </div>
            }
        </div>

        <div class="field field-full" id="importRegistryFields">
            <div class="grid-2">
                <div class="field">
                    <label asp-for="ImportRegistrySourceMode"></label>
                    <select asp-for="ImportRegistrySourceMode" asp-items="Model.ImportRegistrySourceModeOptions" class="dashboard-select" id="importRegistrySourceModeSelect">
                        <option value="">Select source mode...</option>
                    </select>
                    <span asp-validation-for="ImportRegistrySourceMode" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="ImportRegistryExecuteMode"></label>
                    <select asp-for="ImportRegistryExecuteMode" asp-items="Model.ImportRegistryExecuteModeOptions" class="dashboard-select" id="importRegistryExecuteModeSelect">
                        <option value="">Select execute mode...</option>
                    </select>
                    <span asp-validation-for="ImportRegistryExecuteMode" class="text-danger"></span>
                </div>
            </div>

            <div id="importRegistryPackageField">
                <div class="field">
                    <label asp-for="ImportRegistryPackageId"></label>
                    <select asp-for="ImportRegistryPackageId" asp-items="Model.ImportRegistryPackageOptions" class="dashboard-select" id="importRegistryPackageIdSelect">
                        <option value="">Select a .reg package...</option>
                    </select>
                    <span asp-validation-for="ImportRegistryPackageId" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.SelectedRegistryPackageSummary))
                {
                    <div class="cell-secondary" style="margin-top:8px;">
                        @Model.SelectedRegistryPackageSummary
                    </div>
                }
            </div>

            <div id="importRegistryUploadField">
                <div class="field">
                    <label asp-for="ImportRegistryUploadFile"></label>
                    <input asp-for="ImportRegistryUploadFile" type="file" accept=".reg" />
                    <span asp-validation-for="ImportRegistryUploadFile" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.UploadedRegistryFileName))
                {
                    <div class="cell-secondary" style="margin-top:8px;">
                        Current uploaded file: @Model.UploadedRegistryFileName
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.UploadedRegistryDownloadUrl))
                    {
                        <div class="cell-secondary" style="margin-top:6px;">
                            Current source:
                            <a href="@Model.UploadedRegistryDownloadUrl" target="_blank" rel="noopener noreferrer">
                                @Model.UploadedRegistryDownloadUrl
                            </a>
                        </div>
                    }
                }
            </div>

            <div class="cell-secondary" style="margin-top:8px;">
                ImportRegistryFile can use an existing .reg package or upload a .reg file directly to the server distro.
            </div>
        </div>

        <div class="field field-full" id="writeFileFields">
            <div class="grid-2">
                <div class="field">
                    <label asp-for="WriteFilePath"></label>
                    <input asp-for="WriteFilePath" placeholder="C:\RetailCentral\Apps\config\example.txt" id="writeFilePathInput" />
                    <span asp-validation-for="WriteFilePath" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="WriteFileSourceMode"></label>
                    <select asp-for="WriteFileSourceMode" asp-items="Model.WriteFileSourceModeOptions" class="dashboard-select" id="writeFileSourceModeSelect">
                        <option value="">Select source mode...</option>
                    </select>
                    <span asp-validation-for="WriteFileSourceMode" class="text-danger"></span>
                </div>
            </div>

            <div class="field">
                <label class="checkbox-label">
                    <input asp-for="WriteFileOverwrite" type="checkbox" />
                    <span>Overwrite Existing File</span>
                </label>
            </div>

            <div id="writeFileInlineFields">
                <div class="grid-2">
                    <div class="field">
                        <label asp-for="WriteFileEncoding"></label>
                        <select asp-for="WriteFileEncoding" asp-items="Model.WriteFileEncodingOptions" class="dashboard-select" id="writeFileEncodingSelect">
                            <option value="">Select encoding...</option>
                        </select>
                        <span asp-validation-for="WriteFileEncoding" class="text-danger"></span>
                    </div>
                </div>

                <div class="field field-full">
                    <label asp-for="WriteFileContent"></label>
                    <textarea asp-for="WriteFileContent" rows="8" id="writeFileContentInput"></textarea>
                    <span asp-validation-for="WriteFileContent" class="text-danger"></span>
                </div>
            </div>

            <div id="writeFileUploadField">
                <div class="field">
                    <label asp-for="WriteFileUploadFile"></label>
                    <input asp-for="WriteFileUploadFile" type="file" />
                    <span asp-validation-for="WriteFileUploadFile" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.UploadedWriteFileName))
                {
                    <div class="cell-secondary" style="margin-top:8px;">
                        Current uploaded file: @Model.UploadedWriteFileName
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.UploadedWriteFileDownloadUrl))
                    {
                        <div class="cell-secondary" style="margin-top:6px;">
                            Current source:
                            <a href="@Model.UploadedWriteFileDownloadUrl" target="_blank" rel="noopener noreferrer">
                                @Model.UploadedWriteFileDownloadUrl
                            </a>
                        </div>
                    }
                }
            </div>

            <div class="cell-secondary" style="margin-top:8px;">
                WriteFile can use inline content or upload a file directly to the server distro before writing it to the target path.
            </div>
        </div>

        <div class="field">
            <label asp-for="TimeoutSeconds"></label>
            <input asp-for="TimeoutSeconds" type="number" min="1" max="3600" />
            <span asp-validation-for="TimeoutSeconds" class="text-danger"></span>
        </div>

        <div class="field">
            <label asp-for="MaxRetries"></label>
            <input asp-for="MaxRetries" type="number" min="0" max="20" />
            <span asp-validation-for="MaxRetries" class="text-danger"></span>
        </div>

        <div class="field">
            <label asp-for="OnFailureAction"></label>
            <select asp-for="OnFailureAction" asp-items="Model.OnFailureActionOptions" class="dashboard-select">
                <option value="">Select failure action...</option>
            </select>
            <span asp-validation-for="OnFailureAction" class="text-danger"></span>

            <div class="cell-secondary" style="margin-top:8px;">
                <strong>Failure action guide:</strong><br />
                <strong>FailRun</strong> - Stop the orchestration and mark the run as failed.<br />
                <strong>RetryStep</strong> - Retry the current step up to the allowed retry count.<br />
                <strong>Continue</strong> - Continue to the next step even if this step fails.<br />
                <strong>Rollback</strong> - Attempt defined rollback behavior, if available.<br />
                <strong>Escalate</strong> - Mark the failure for operator attention or escalation.
            </div>
        </div>

        <div class="field">
            <label class="checkbox-label" style="margin-top:32px;">
                <input asp-for="ContinueOnFailure" type="checkbox" />
                <span>Continue On Failure</span>
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">@submitText</button>
            <a asp-action="OrchestrationTemplate" asp-route-id="@Model.TemplateId" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const stepTypeSelect = document.getElementById('stepTypeSelect');
            const commandTypeSelect = document.getElementById('commandTypeSelect');
            const commandTypeHidden = document.getElementById('commandTypeHidden');
            const stepTypeDescription = document.getElementById('stepTypeDescription');
            const commandTypeDescription = document.getElementById('commandTypeDescription');
            const validateProcessField = document.getElementById('validateProcessField');
            const validateProcessNameInput = document.getElementById('validateProcessNameInput');
            const validateRegistryFields = document.getElementById('validateRegistryFields');
            const installPackageFields = document.getElementById('installPackageFields');
            const writeFileFields = document.getElementById('writeFileFields');
            const importRegistryFields = document.getElementById('importRegistryFields');
            const importRegistrySourceModeSelect = document.getElementById('importRegistrySourceModeSelect');
            const importRegistryPackageField = document.getElementById('importRegistryPackageField');
            const importRegistryUploadField = document.getElementById('importRegistryUploadField');
            const writeFileSourceModeSelect = document.getElementById('writeFileSourceModeSelect');
            const writeFileInlineFields = document.getElementById('writeFileInlineFields');
            const writeFileUploadField = document.getElementById('writeFileUploadField');

            function requiresCommandType(stepTypeText) {
                if (!stepTypeText) return false;

                const value = stepTypeText.toLowerCase();
                return value.includes('command')
                    || value.includes('validate')
                    || value.includes('validation')
                    || value.includes('install')
                    || value.includes('restart')
                    || value.includes('collect')
                    || value.includes('write')
                    || value.includes('apply')
                    || value.includes('import')
                    || value.includes('registry')
                    || value.includes('script');
            }

            function getStepTypeText() {
                const selected = stepTypeSelect.options[stepTypeSelect.selectedIndex];
                return selected ? selected.text || '' : '';
            }

            function getMappedCommandTypeForStepType(stepTypeText) {
                const value = (stepTypeText || '').toLowerCase();

                if (value === 'installpackage') return 'InstallPackage';
                if (value === 'writefile') return 'WriteFile';
                if (value === 'importregistryfile') return 'ImportRegistryFile';
                if (value === 'validateregistry') return 'ValidateRegistry';
                if (value === 'validateprocess') return 'ValidateProcess';

                return '';
            }

            function getCommandTypeValue() {
                return commandTypeSelect.value || '';
            }

            function getImportRegistrySourceMode() {
                return importRegistrySourceModeSelect ? (importRegistrySourceModeSelect.value || '') : '';
            }

            function updateImportRegistrySourceUi() {
                const sourceMode = getImportRegistrySourceMode().toLowerCase();

                if (sourceMode === 'upload') {
                    importRegistryPackageField.style.display = 'none';
                    importRegistryUploadField.style.display = '';
                } else {
                    importRegistryPackageField.style.display = '';
                    importRegistryUploadField.style.display = 'none';
                }
            }

            function getWriteFileSourceMode() {
                return writeFileSourceModeSelect ? (writeFileSourceModeSelect.value || '') : '';
            }

            function updateWriteFileSourceUi() {
                const sourceMode = getWriteFileSourceMode().toLowerCase();

                if (sourceMode === 'upload') {
                    writeFileInlineFields.style.display = 'none';
                    writeFileUploadField.style.display = '';
                } else {
                    writeFileInlineFields.style.display = '';
                    writeFileUploadField.style.display = 'none';
                }
            }

            function hideAllGuidedFields() {
                validateProcessField.style.display = 'none';
                validateRegistryFields.style.display = 'none';
                installPackageFields.style.display = 'none';
                importRegistryFields.style.display = 'none';
                importRegistryPackageField.style.display = 'none';
                importRegistryUploadField.style.display = 'none';
                writeFileFields.style.display = 'none';
                writeFileInlineFields.style.display = 'none';
                writeFileUploadField.style.display = 'none';
            }

            function updateUi() {
                const stepTypeText = getStepTypeText();
                const loweredStepType = (stepTypeText || '').toLowerCase();
                const stepRequiresCommand = requiresCommandType(stepTypeText);
                const mappedCommandType = getMappedCommandTypeForStepType(stepTypeText);

                if (mappedCommandType) {
                    commandTypeSelect.value = mappedCommandType;
                }

                const commandTypeValue = getCommandTypeValue();

                if (stepRequiresCommand) {
                    if (mappedCommandType) {
                        commandTypeSelect.disabled = true;
                        commandTypeHidden.disabled = false;
                        commandTypeHidden.value = mappedCommandType;
                    } else {
                        commandTypeSelect.disabled = false;
                        commandTypeHidden.disabled = true;
                        commandTypeHidden.value = '';
                    }

                    if (loweredStepType.includes('write')
                        || loweredStepType.includes('apply')
                        || loweredStepType.includes('import')
                        || loweredStepType.includes('registry')
                        || loweredStepType.includes('script')) {
                        stepTypeDescription.textContent = 'This step type is recognized as executable and maps to a guided command flow.';
                    } else {
                        stepTypeDescription.textContent = 'This step type is currently treated as command-backed and requires a Command Type.';
                    }
                } else {
                    commandTypeSelect.disabled = true;
                    commandTypeSelect.value = '';
                    commandTypeHidden.disabled = false;
                    commandTypeHidden.value = '';
                    stepTypeDescription.textContent = stepTypeText
                        ? 'This step type is currently treated as non-command orchestration behavior. Command Type does not apply.'
                        : 'Choose a step type to see how this step behaves.';
                }

                if (!stepRequiresCommand) {
                    commandTypeDescription.textContent = 'Choose a command type to see guided parameter options.';
                    validateProcessNameInput.value = '';
                    hideAllGuidedFields();
                    return;
                }

                if (commandTypeValue.toLowerCase() === 'validateprocess') {
                    commandTypeDescription.textContent = 'ValidateProcess requires a process name and will store it as structured step parameters.';
                    hideAllGuidedFields();
                    validateProcessField.style.display = '';
                } else if (commandTypeValue.toLowerCase() === 'validateregistry') {
                    commandTypeDescription.textContent = 'ValidateRegistry checks that a registry value exists and matches the expected value.';
                    hideAllGuidedFields();
                    validateRegistryFields.style.display = '';
                } else if (commandTypeValue.toLowerCase() === 'restartpos') {
                    commandTypeDescription.textContent = 'RestartPOS does not require additional parameters.';
                    hideAllGuidedFields();
                } else if (commandTypeValue.toLowerCase() === 'collectsysteminfo') {
                    commandTypeDescription.textContent = 'CollectSystemInfo does not require additional parameters.';
                    hideAllGuidedFields();
                } else if (commandTypeValue.toLowerCase() === 'installpackage') {
                    commandTypeDescription.textContent = 'InstallPackage uses a guided package selector and generates the install payload automatically.';
                    hideAllGuidedFields();
                    installPackageFields.style.display = '';
                } else if (commandTypeValue.toLowerCase() === 'importregistryfile') {
                    commandTypeDescription.textContent = 'ImportRegistryFile can use an existing .reg package or upload a .reg file directly to the server distro.';
                    hideAllGuidedFields();
                    importRegistryFields.style.display = '';
                    updateImportRegistrySourceUi();
                } else if (commandTypeValue.toLowerCase() === 'writefile') {
                    commandTypeDescription.textContent = 'WriteFile writes controlled content to a trusted local path using inline content or an uploaded file.';
                    hideAllGuidedFields();
                    writeFileFields.style.display = '';
                    updateWriteFileSourceUi();
                } else if (!commandTypeValue) {
                    commandTypeDescription.textContent = 'Choose a command type to see guided parameter options.';
                    hideAllGuidedFields();
                } else {
                    commandTypeDescription.textContent = 'This command type is recognized, but guided parameter support is not implemented yet.';
                    hideAllGuidedFields();
                }
            }

            if (writeFileSourceModeSelect) {
                writeFileSourceModeSelect.addEventListener('change', updateUi);
            }

            if (stepTypeSelect) {
                stepTypeSelect.addEventListener('change', updateUi);
            }

            if (commandTypeSelect) {
                commandTypeSelect.addEventListener('change', updateUi);
            }

            if (importRegistrySourceModeSelect) {
                importRegistrySourceModeSelect.addEventListener('change', updateUi);
            }

            updateUi();
        })();
    </script>
}
