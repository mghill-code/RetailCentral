@model List<RetailCentral.Api.ViewModels.GroupSummaryViewModel>

@{
    ViewData["Title"] = "Groups";
}

<div class="page-header">
    <div>
        <h1>Device Groups</h1>
        <p>Create logical targeting groups and bulk import members for store or pilot rollouts.</p>
    </div>
</div>

@if (TempData["GroupMessage"] != null)
{
    <div class="alert alert-success">@TempData["GroupMessage"]</div>
}

<div class="grid-2">
    <div class="card">
        <h3>Create Group</h3>
        <form method="post" action="/Dashboard/CreateGroup" class="section-stack">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Group Name</label>
                    <input type="text" name="groupName" placeholder="Example: Pilot Stores - Registers" />
                </div>
                <div class="col-md-6">
                    <label>Description</label>
                    <input type="text" name="description" placeholder="Optional description" />
                </div>
            </div>
            <div class="action-row"><button type="submit">Create Group</button></div>
        </form>
    </div>

    <div class="card">
        <h3>Import Group from CSV</h3>
        <form method="post" action="/Dashboard/ImportGroupCsv" enctype="multipart/form-data" class="section-stack">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Group Name</label>
                    <input type="text" name="groupName" placeholder="New or existing group name" />
                </div>
                <div class="col-md-6">
                    <label for="csvFile">CSV File</label>

                    <div class="file-upload">
                        <input type="file" id="csvFile" name="csvFile" accept=".csv" />
                        <label for="csvFile" class="file-upload-button">Choose CSV</label>
                        <span class="file-upload-name" id="csvFileName">No file chosen</span>
                    </div>
                </div>
            </div>
            <div class="action-row"><button type="submit">Import CSV</button></div>
        </form>

        <div class="group-import-help">
            <h4>CSV Instructions</h4>
            <p class="subtle">Upload a CSV with a header row. The importer supports the formats below.</p>
            <div class="group-import-format-grid">
                <div class="group-import-format">
                    <strong>Recommended</strong>
<pre>StoreNumber,Hostname
84420,BNC84420-001
84420,BNC84420-002
84420,BNC84420-003</pre>
                </div>
                <div class="group-import-format">
                    <strong>Hostname only</strong>
<pre>Hostname
BNC84420-001
BNC84420-002
BNC84420-003</pre>
                </div>
                <div class="group-import-format">
                    <strong>DeviceId only</strong>
<pre>DeviceId
11111111-1111-1111-1111-111111111111
22222222-2222-2222-2222-222222222222</pre>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <h3>Existing Groups</h3>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:28%;">Group Name</th>
                    <th style="width:34%;">Description</th>
                    <th style="width:12%;">Members</th>
                    <th style="width:16%;">Created</th>
                    <th style="width:10%;">Open</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model)
                {
                    <tr>
                        <td><strong>@g.GroupName</strong></td>
                        <td>@(string.IsNullOrWhiteSpace(g.Description) ? "-" : g.Description)</td>
                        <td>@g.MemberCount</td>
                        <td>@g.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><a class="btn btn-outline" href="/Dashboard/Group?groupName=@Uri.EscapeDataString(g.GroupName)">Open</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById("csvFile");
            const fileName = document.getElementById("csvFileName");

            if (!input || !fileName) return;

            input.addEventListener("change", function () {
                if (input.files && input.files.length > 0) {
                    fileName.textContent = input.files[0].name;
                } else {
                    fileName.textContent = "No file chosen";
                }
            });
        })();
    </script>
}