{
  "Server": {
    "BaseUrl": "http://localhost:5149"
  },
  "Agent": {
    "StoreNumber": "",
    "RegisterNumber": "",
    "Hostname": "",
    "AgentVersion": "0.9.0",
    "DeviceId": "",
    "DeviceSecret": "",
    "BootstrapKey": "RetailCentralEnroll2026",
    "DeviceSecretProtected": "",
    "PollSeconds": 10,
    "HeartbeatSeconds": 30,
    "MaxPendingFetch": 1,
    "RegisterMetadataPath": ""
  },
  "ProcessMonitoring": {
    "PosProcessName": "bncpos",
    "RetailShellProcessName": "RetailShell",
    "AgentProcessName": "RetailCentral.Agent"
  },
  "Execution": {
    "DefaultTimeoutSeconds": 30,
    "MaxTimeoutSeconds": 900,
    "MaxStdoutChars": 100000,
    "MaxStderrChars": 100000,
    "InstallCheckSeconds": 30,
    "AllowRunProcess": false,
    "RequireAbsolutePath": true,
    "DisallowRelativePaths": true,
    "DisallowUNCPaths": true,
    "DisallowCmdExe": true,
    "DisallowPowershell": true,
    "AllowedCommands": [
      "Echo",
      "CollectSystemInfo",
      "CollectProcessStatus",
      "CollectSoftwareInventory",
      "DownloadFile",
      "InstallPackage",
      "RestartPOS",
      "RestartRetailShell",
      "RestartAgent",
      "RebootDevice"
    ],
    "TrustedExecutionRoots": [
      "C:\\BNCPOS\\",
      "C:\\RetailCentral\\Apps\\",
      "C:\\RetailCentral\\Helpers\\",
      "C:\\RetailCentral\\RetailShell\\",
      "C:\\RetailCentral\\Agent\\staging\\"
    ],
    "BlockedPathPrefixes": [
      "\\\\",
      "C:\\Users\\",
      "C:\\Windows\\Temp\\",
      "C:\\Temp\\"
    ],
    "AllowedExecutables": [
      {
        "Name": "RetailShellRestart",
        "Path": "C:\\RetailCentral\\RetailShell\\RetailShell.exe",
        "WorkingDirectory": "C:\\RetailCentral\\RetailShell",
        "TimeoutSeconds": 60
      },
      {
        "Name": "AgentRestart",
        "Path": "C:\\RetailCentral\\Helpers\\RetailCentral.Agent.RestartHelper.exe",
        "WorkingDirectory": "C:\\RetailCentral\\Helpers",
        "TimeoutSeconds": 60,
        "AllowedArgumentsRegex": [
          "^RetailCentral\\.Agent(\\s+[0-9]{1,2})?$"
        ]
      },
      {
        "Name": "MsiexecInstall",
        "Path": "C:\\Windows\\System32\\msiexec.exe",
        "WorkingDirectory": "C:\\RetailCentral\\Agent\\staging",
        "TimeoutSeconds": 900,
        "AllowedArgumentsRegex": [
          "^/i\\s+\"C:\\\\RetailCentral\\\\Agent\\\\staging\\\\[A-Za-z0-9._-]+\\.msi\"\\s+/qn\\s*/norestart$"
        ]
      }
    ]
  },
  "Downloads": {
    "RootFolder": "C:\\RetailCentral\\Agent\\downloads",
    "StagingRootFolder": "C:\\RetailCentral\\Agent\\staging"
  },
  "UserActivity": {
    "Enabled": true,
    "SnapshotPath": "C:\\RetailCentral\\RetailShell\\Shared\\UserActivity.json"
  }
}
